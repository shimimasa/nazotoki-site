        <div class="py-2">
          <div class="text-xs font-bold text-gray-400 uppercase tracking-wider px-3 py-1">教科で探す</div>
          <div class="grid grid-cols-2 gap-1">
            <a href={`${import.meta.env.BASE_URL}series/time-travel/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-slate-50 no-underline">
              <span>🕰️</span> 歴史
            </a>
            <a href={`${import.meta.env.BASE_URL}series/literature/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-slate-50 no-underline">
              <span>📖</span> 国語
            </a>
            <a href={`${import.meta.env.BASE_URL}series/popculture/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-slate-50 no-underline">
              <span>🎭</span> 教養

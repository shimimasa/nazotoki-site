          <a href={`${import.meta.env.BASE_URL}for/teachers/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-slate-50 no-underline">
            <svg class="w-5 h-5 text-slate-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9.674 2.075a.75.75 0 0 1 .652 0l7.25 3.5A.75.75 0 0 1 17.5 7v.04c-.067.446-.502.75-.948.75H3.448c-.446 0-.881-.304-.948-.75V7a.75.75 0 0 1-.076-1.425l7.25-3.5ZM10 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2ZM3.5 9.5v5.25h1V9.5h-1Zm2 0v5.25h1V9.5h-1Zm3 0v5.25h1V9.5h-1Zm2 0v5.25h1V9.5h-1Zm3 0v5.25h1V9.5h-1Zm2 0v5.25h1V9.5h-1ZM2.25 17.5a.75.75 0 0 1 .75-.75h14a.75.75 0 0 1 0 1.5H3a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/></svg>
            <span class="font-bold text-sm">授業で使う</span>
          </a>
          <a href={`${import.meta.env.BASE_URL}for/beginners/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-slate-50 no-underline">
            <svg class="w-5 h-5 text-slate-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M2 10a8 8 0 1 1 16 0 8 8 0 0 1-16 0Zm6.39-2.908a.75.75 0 0 1 .766.027l3.5 2.25a.75.75 0 0 1 0 1.262l-3.5 2.25A.75.75 0 0 1 8 12.25v-4.5a.75.75 0 0 1 .39-.658Z" clip-rule="evenodd"/></svg>

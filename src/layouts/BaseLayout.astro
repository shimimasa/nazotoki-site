            </a>
            <a href={`${import.meta.env.BASE_URL}series/science/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-slate-50 no-underline">
              <span>🔬</span> 理科
            </a>
            <a href={`${import.meta.env.BASE_URL}series/moral/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-slate-50 no-underline">
              <span>⚖️</span> 道徳
            </a>

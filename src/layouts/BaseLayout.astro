---
import '../styles/global.css';
import recommendationsData from '../data/meta/recommendations.json';

const siteUpdatedAt = (recommendationsData as any).siteUpdatedAt || '';

interface Props {
  title: string;
  description?: string;
  noIndex?: boolean;
  ogImage?: string;
  fullWidth?: boolean;
}

const { title, description = '教科の知識で謎を解く教育マーダーミステリー「ナゾトキ探偵団」— 全100シナリオ無料', noIndex = false, ogImage, fullWidth = false } = Astro.props;
const siteName = 'ナゾトキ探偵団';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage ? new URL(`${import.meta.env.BASE_URL}${ogImage.replace(/^\//, '')}`, Astro.site).href : undefined;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex" />}
  <!-- OGP -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="ja_JP" />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  <!-- Twitter Card -->
  <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
  <meta name="twitter:site" content="@smz_nazotoki" />
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet" />
  <title>{fullTitle}</title>
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 font-sans antialiased">
  <header class="bg-white border-b border-gray-200 print:hidden">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 text-gray-900 hover:text-amber-700 transition-colors no-underline flex-shrink-0">
        <span class="text-2xl">🔍</span>
        <span class="font-black text-lg tracking-tight hidden sm:inline">ナゾトキ探偵団</span>
      </a>

      {/* === PC用ナビ（sm以上） === */}
      <div class="ml-auto hidden sm:flex items-center gap-4">
        {/* シリーズドロップダウン */}
        <div class="relative" id="series-dropdown">
          <button
            type="button"
            class="text-sm text-gray-500 hover:text-amber-600 transition-colors font-bold flex items-center gap-1"
            id="series-dropdown-btn"
          >
            📚 教科 <span class="text-xs">▼</span>
          </button>
          <div id="series-dropdown-menu" class="hidden absolute right-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 w-56 py-2">
            <a href={`${import.meta.env.BASE_URL}series/time-travel/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-amber-50 no-underline">
              <span>🕰️</span> タイムトラベル探偵団
            </a>
            <a href={`${import.meta.env.BASE_URL}series/literature/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 no-underline">
              <span>📖</span> 名作文学ミステリー
            </a>
            <a href={`${import.meta.env.BASE_URL}series/popculture/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-purple-50 no-underline">
              <span>🎭</span> マンガ教養ミステリー
            </a>
            <a href={`${import.meta.env.BASE_URL}series/math/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-emerald-50 no-underline">
              <span>🔢</span> 数字の迷宮
            </a>
            <a href={`${import.meta.env.BASE_URL}series/science/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 no-underline">
              <span>🔬</span> サイエンス捜査班
            </a>
            <a href={`${import.meta.env.BASE_URL}series/moral/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-orange-50 no-underline">
              <span>⚖️</span> 答えのない法廷
            </a>
          </div>
        </div>
        {/* はじめての方ドロップダウン */}
        <div class="relative" id="beginners-dropdown">
          <button
            type="button"
            class="text-sm text-gray-500 hover:text-amber-600 transition-colors font-bold flex items-center gap-1"
            id="beginners-dropdown-btn"
          >
            ✨ はじめての方 <span class="text-xs">▼</span>
          </button>
          <div id="beginners-dropdown-menu" class="hidden absolute right-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 w-56 py-2">
            <a href={`${import.meta.env.BASE_URL}for/parents/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-amber-50 no-underline">
              <span>🏠</span> 親子ではじめる
            </a>
            <a href={`${import.meta.env.BASE_URL}for/teachers/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 no-underline">
              <span>🏫</span> 授業で使う
            </a>
            <a href={`${import.meta.env.BASE_URL}for/beginners/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 no-underline">
              <span>🎮</span> GM初心者ガイド
            </a>
            <div class="border-t border-gray-100 my-1"></div>
            <a href={`${import.meta.env.BASE_URL}guide/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 no-underline">
              <span>📘</span> 遊び方ガイド
            </a>
          </div>
        </div>
        <a href={`${import.meta.env.BASE_URL}challenge/`} class="text-sm text-gray-500 hover:text-amber-600 transition-colors no-underline font-bold">🧩 今日のナゾトキ</a>
        <a href={`${import.meta.env.BASE_URL}dashboard/`} class="text-sm text-gray-500 hover:text-amber-600 transition-colors no-underline font-bold">📊 ダッシュボード</a>
      </div>

      {/* === モバイル用ハンバーガー（sm未満） === */}
      <button
        type="button"
        id="mobile-menu-btn"
        class="ml-auto sm:hidden flex items-center justify-center w-10 h-10 rounded-lg text-gray-500 hover:text-amber-600 hover:bg-gray-100 transition-colors"
        aria-label="メニューを開く"
        aria-expanded="false"
      >
        <svg id="mobile-menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="mobile-menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    {/* === モバイルメニューパネル === */}
    <div id="mobile-menu-panel" class="hidden sm:hidden border-t border-gray-100 bg-white">
      <nav class="max-w-5xl mx-auto px-4 py-4 space-y-1">
        {/* はじめての方 */}
        <div class="pb-2">
          <div class="text-xs font-bold text-gray-400 uppercase tracking-wider px-3 py-1">はじめての方</div>
          <a href={`${import.meta.env.BASE_URL}for/parents/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-amber-50 no-underline">
            <span class="text-lg">🏠</span> <span class="font-bold text-sm">親子ではじめる</span>
          </a>
          <a href={`${import.meta.env.BASE_URL}for/teachers/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-blue-50 no-underline">
            <span class="text-lg">🏫</span> <span class="font-bold text-sm">授業で使う</span>
          </a>
          <a href={`${import.meta.env.BASE_URL}for/beginners/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-green-50 no-underline">
            <span class="text-lg">🎮</span> <span class="font-bold text-sm">GM初心者ガイド</span>
          </a>
        </div>

        <div class="border-t border-gray-100"></div>

        {/* 教科で探す */}
        <div class="py-2">
          <div class="text-xs font-bold text-gray-400 uppercase tracking-wider px-3 py-1">教科で探す</div>
          <div class="grid grid-cols-2 gap-1">
            <a href={`${import.meta.env.BASE_URL}series/time-travel/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-amber-50 no-underline">
              <span>🕰️</span> 歴史
            </a>
            <a href={`${import.meta.env.BASE_URL}series/literature/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-indigo-50 no-underline">
              <span>📖</span> 国語
            </a>
            <a href={`${import.meta.env.BASE_URL}series/popculture/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-purple-50 no-underline">
              <span>🎭</span> 教養
            </a>
            <a href={`${import.meta.env.BASE_URL}series/math/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-emerald-50 no-underline">
              <span>🔢</span> 算数
            </a>
            <a href={`${import.meta.env.BASE_URL}series/science/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-blue-50 no-underline">
              <span>🔬</span> 理科
            </a>
            <a href={`${import.meta.env.BASE_URL}series/moral/`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 no-underline">
              <span>⚖️</span> 道徳
            </a>
          </div>
        </div>

        <div class="border-t border-gray-100"></div>

        {/* その他 */}
        <div class="pt-2">
          <a href={`${import.meta.env.BASE_URL}challenge/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-amber-50 no-underline">
            <span class="text-lg">🧩</span> <span class="font-bold text-sm">今日のナゾトキ</span>
          </a>
          <a href={`${import.meta.env.BASE_URL}guide/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 no-underline">
            <span class="text-lg">📘</span> <span class="font-bold text-sm">遊び方ガイド</span>
          </a>
          <a href={`${import.meta.env.BASE_URL}dashboard/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 no-underline">
            <span class="text-lg">📊</span> <span class="font-bold text-sm">教員ダッシュボード</span>
          </a>
        </div>
      </nav>
    </div>
  </header>
  <script>
    // PC用ドロップダウン
    function setupDropdown(btnId, menuId) {
      const btn = document.getElementById(btnId);
      const menu = document.getElementById(menuId);
      if (!btn || !menu) return;
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.querySelectorAll('[id$="-dropdown-menu"]').forEach(m => {
          if (m !== menu) m.classList.add('hidden');
        });
        menu.classList.toggle('hidden');
      });
    }
    setupDropdown('series-dropdown-btn', 'series-dropdown-menu');
    setupDropdown('beginners-dropdown-btn', 'beginners-dropdown-menu');
    document.addEventListener('click', () => {
      document.querySelectorAll('[id$="-dropdown-menu"]').forEach(m => m.classList.add('hidden'));
    });

    // モバイルハンバーガーメニュー
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobilePanel = document.getElementById('mobile-menu-panel');
    const iconOpen = document.getElementById('mobile-menu-icon-open');
    const iconClose = document.getElementById('mobile-menu-icon-close');
    if (mobileBtn && mobilePanel && iconOpen && iconClose) {
      mobileBtn.addEventListener('click', () => {
        const isOpen = !mobilePanel.classList.contains('hidden');
        mobilePanel.classList.toggle('hidden');
        iconOpen.classList.toggle('hidden', !isOpen);
        iconClose.classList.toggle('hidden', isOpen);
        mobileBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });
    }
  </script>

  <main class={fullWidth ? '' : 'max-w-5xl mx-auto px-4 py-8'}>
    <slot />
  </main>

  <footer class={`border-t border-gray-200 print:hidden bg-gray-50 ${fullWidth ? '' : 'mt-16'}`}>
    <div class="max-w-5xl mx-auto px-4 py-8">
      <div class="grid gap-8 sm:grid-cols-3">
        {/* シリーズ */}
        <div>
          <h3 class="font-bold text-sm text-gray-700 mb-3">シリーズ</h3>
          <ul class="space-y-1.5 text-sm text-gray-500">
            <li><a href={`${import.meta.env.BASE_URL}series/time-travel/`} class="hover:text-gray-700 no-underline">🕰️ タイムトラベル探偵団</a></li>
            <li><a href={`${import.meta.env.BASE_URL}series/literature/`} class="hover:text-gray-700 no-underline">📖 名作文学ミステリー</a></li>
            <li><a href={`${import.meta.env.BASE_URL}series/popculture/`} class="hover:text-gray-700 no-underline">🎭 マンガ教養ミステリー</a></li>
            <li><a href={`${import.meta.env.BASE_URL}series/math/`} class="hover:text-gray-700 no-underline">🔢 数字の迷宮</a></li>
            <li><a href={`${import.meta.env.BASE_URL}series/science/`} class="hover:text-gray-700 no-underline">🔬 サイエンス捜査班</a></li>
            <li><a href={`${import.meta.env.BASE_URL}series/moral/`} class="hover:text-gray-700 no-underline">⚖️ 答えのない法廷</a></li>
          </ul>
        </div>
        {/* ガイド・ツール */}
        <div>
          <h3 class="font-bold text-sm text-gray-700 mb-3">ガイド・ツール</h3>
          <ul class="space-y-1.5 text-sm text-gray-500">
            <li><a href={`${import.meta.env.BASE_URL}for/parents/`} class="hover:text-gray-700 no-underline">🏠 親子ではじめる</a></li>
            <li><a href={`${import.meta.env.BASE_URL}for/teachers/`} class="hover:text-gray-700 no-underline">🏫 授業で使う</a></li>
            <li><a href={`${import.meta.env.BASE_URL}for/beginners/`} class="hover:text-gray-700 no-underline">🎮 GM初心者ガイド</a></li>
            <li><a href={`${import.meta.env.BASE_URL}guide/`} class="hover:text-gray-700 no-underline">📘 遊び方ガイド</a></li>
            <li><a href={`${import.meta.env.BASE_URL}challenge/`} class="hover:text-gray-700 no-underline">🧩 今日のナゾトキ</a></li>
            <li><a href={`${import.meta.env.BASE_URL}dashboard/`} class="hover:text-gray-700 no-underline">📊 教員ダッシュボード</a></li>
          </ul>
        </div>
        {/* リンク */}
        <div>
          <h3 class="font-bold text-sm text-gray-700 mb-3">リンク</h3>
          <ul class="space-y-1.5 text-sm text-gray-500">
            <li><a href="https://x.com/smz_nazotoki" class="hover:text-gray-700 no-underline" target="_blank" rel="noopener">X (@smz_nazotoki)</a></li>
            <li><a href="https://note.com/masa0714" class="hover:text-gray-700 no-underline" target="_blank" rel="noopener">note</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-200 mt-6 pt-4 text-center text-xs text-gray-400">
        <p>ナゾトキ探偵団 &mdash; 現役教員が設計した教育マーダーミステリー</p>
        <p class="mt-2">
          <a href="https://x.com/smz_nazotoki" class="hover:text-gray-600 no-underline">お問い合わせ (X)</a>
        </p>
        {siteUpdatedAt && <p class="mt-1">最終更新: {siteUpdatedAt}</p>}
      </div>
    </div>
  </footer>
  <!-- Goatcounter: 無料・Cookie不使用・プライバシーフレンドリー -->
  <!-- 要セットアップ: https://www.goatcounter.com で smz-nazotoki サイトを作成 -->
  <script data-goatcounter="https://smz-nazotoki.goatcounter.com/count"
          async src="//gc.zgo.at/count.js"></script>
</body>
</html>

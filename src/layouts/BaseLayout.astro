---
import '../styles/global.css';
import recommendationsData from '../data/meta/recommendations.json';

const siteUpdatedAt = (recommendationsData as any).siteUpdatedAt || '';

interface Props {
  title: string;
  description?: string;
  noIndex?: boolean;
  ogImage?: string;
  fullWidth?: boolean;
}

const { title, description = '教科の知識で謎を解く教育マーダーミステリー「ナゾトキ探偵団」— 全100シナリオ無料', noIndex = false, ogImage, fullWidth = false } = Astro.props;
const siteName = 'ナゾトキ探偵団';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const defaultOgImage = `${import.meta.env.BASE_URL}og/top.png`;
const ogImageUrl = new URL(
  ogImage
    ? `${import.meta.env.BASE_URL}${ogImage.replace(/^\//, '')}`
    : defaultOgImage,
  Astro.site
).href;

// JSON-LD 構造化データ
const jsonLdOrg = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": siteName,
  "url": Astro.site?.href,
  "description": "現役教員が設計した教育マーダーミステリー。全100シナリオ無料。",
  "sameAs": [
    "https://x.com/smz_nazotoki",
    "https://note.com/masa0714",
    "https://smz-nazotoki.booth.pm/"
  ]
};
const jsonLdWebsite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": Astro.site?.href,
  "description": "教科の知識で謎を解く教育マーダーミステリー。全100シナリオ無料。",
  "inLanguage": "ja"
};
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex" />}
  <!-- OGP -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@smz_nazotoki" />
  <meta name="twitter:image" content={ogImageUrl} />
  <!-- JSON-LD 構造化データ -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrg)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebsite)} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet" />
  <title>{fullTitle}</title>
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 font-sans antialiased">
  <header class="bg-white border-b border-gray-200 print:hidden">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 text-slate-800 hover:text-slate-600 transition-colors no-underline flex-shrink-0">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/></svg>
        <span class="font-black text-lg tracking-tight hidden sm:inline">ナゾトキ探偵団</span>
      </a>

      {/* === PC用ナビ（sm以上） === */}
      <div class="ml-auto hidden sm:flex items-center gap-4">
        {/* シリーズドロップダウン */}
        <div class="relative" id="series-dropdown">
          <button
            type="button"
            class="text-sm text-slate-600 hover:text-slate-800 transition-colors font-bold flex items-center gap-1"
            id="series-dropdown-btn"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>

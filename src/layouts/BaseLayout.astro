        </div>

        <div class="border-t border-gray-100"></div>

        {/* その他 */}
        <div class="pt-2">
          <a href={`${import.meta.env.BASE_URL}challenge/`} class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-slate-50 no-underline">
            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>

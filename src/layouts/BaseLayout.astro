            <a href={`${import.meta.env.BASE_URL}series/time-travel/`} class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-slate-50 no-underline">
              <span>🕰️</span> タイムトラベル探偵団

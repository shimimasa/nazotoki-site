---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeacherWorkspace from '../components/workspace/TeacherWorkspace';
---
<BaseLayout
  title="Teacher Workspace"
  description="授業履歴の管理・振り返り・PDF出力"
  noIndex={true}
>
  <nav class="text-sm text-gray-500 mb-6">
    <a href={import.meta.env.BASE_URL} class="hover:text-gray-700">トップ</a>
    <span class="mx-1">/</span>
    <span>Teacher Workspace</span>
  </nav>

  <div class="mb-6">
    <h1 class="text-3xl font-black">📋 Teacher Workspace</h1>
    <p class="text-gray-500 mt-2">授業履歴の確認・振り返り・PDF出力ができます</p>
  </div>

  <TeacherWorkspace client:load />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeacherAuthGate from '../components/workspace/TeacherAuthGate';
import { loadAllScenarios } from '../lib/data';

const scenarios = loadAllScenarios();
const scenarioList = scenarios.map(s => ({
  slug: s.slug,
  title: s.title,
  series: s.series,
  seriesName: s.seriesName,
  difficulty: s.difficulty,
}));
---
<BaseLayout
  title="Teacher Workspace"
  description="授業履歴の管理・クラス管理・生徒ログ"
  noIndex={true}
>
  <nav class="text-sm text-gray-500 mb-6">
    <a href={import.meta.env.BASE_URL} class="hover:text-gray-700">トップ</a>
    <span class="mx-1">/</span>
    <span>Teacher Workspace</span>
  </nav>

  <div class="mb-6">
    <h1 class="text-3xl font-black">📋 Teacher Workspace</h1>
    <p class="text-gray-500 mt-2">授業履歴・クラス管理・生徒参加ログ</p>
  </div>

  <TeacherAuthGate client:load scenarios={scenarioList} />
</BaseLayout>

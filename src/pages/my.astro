---
import BaseLayout from '../layouts/BaseLayout.astro';
import MyPage from '../components/student/MyPage';
import { loadAllScenarios } from '../lib/data';
import { SERIES_CONFIG } from '../lib/series';

const scenarios = loadAllScenarios();

// Build-time: pass minimal scenario metadata to client.
// Note: characterNames and evidenceTitles are public metadata (same as /play/[slug] pages),
// NOT spoiler content. Actual secrets (evidence body, witness secrets, solutions) are never
// passed here. SSG cannot conditionally exclude data per-user at build time.
const scenarioMeta = scenarios.map(s => ({
  slug: s.slug,
  title: s.title,
  series: s.series,
  seriesName: s.seriesName,
  volume: s.volume,
  difficulty: s.difficulty,
  subject: s.subject,
  thumbnailUrl: s.thumbnailUrl || '',
  characterNames: s.characters.filter(c => !c.isNPC).map(c => c.name.replace(/\{([^}|]+)\|[^}]+\}/g, '$1')),
  evidenceTitles: s.evidenceCards.map(c => c.title.replace(/^証拠カード\d+[：:]/, '').trim()),
}));

// Pass series config to client
const seriesConfig: Record<string, { name: string; emoji: string; color: string }> = {};
for (const [key, cfg] of Object.entries(SERIES_CONFIG)) {
  seriesConfig[key] = { name: cfg.name, emoji: cfg.emoji, color: cfg.color };
}
---
<BaseLayout
  title="マイページ | ナゾトキ探偵団"
  description="あなたの探偵ランクとプレイ履歴を確認しよう"
  noIndex={true}
  fullWidth={true}
>
  <MyPage client:load scenarios={scenarioMeta} seriesConfig={seriesConfig} />
</BaseLayout>

<style is:global>
  /* 生徒用フルスクリーン */
  header, footer { display: none !important; }
  main { padding: 0 !important; margin: 0 !important; max-width: none !important; }
  body { min-height: 100dvh; display: flex; flex-direction: column; }
  main { flex: 1; }
  input, textarea, select { font-size: max(16px, 1em); }
  button, a { -webkit-tap-highlight-color: rgba(0,0,0,0.05); }
</style>

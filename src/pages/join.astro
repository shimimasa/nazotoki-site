---
import BaseLayout from '../layouts/BaseLayout.astro';
import StudentSession from '../components/session/StudentSession';
---
<BaseLayout
  title="セッションに参加"
  description="参加コードを入力してセッションに参加しよう"
  noIndex={true}
  fullWidth={true}
>
  <StudentSession client:load />
</BaseLayout>

<style is:global>
  /* Phase 69: 生徒用フルスクリーン — ヘッダー/フッターを非表示 */
  header, footer { display: none !important; }
  main { padding: 0 !important; margin: 0 !important; max-width: none !important; }
  body { min-height: 100dvh; display: flex; flex-direction: column; }
  main { flex: 1; }

  /* iOS Safari: inputフォーカス時のズーム防止（font-size < 16pxで発生） */
  input, textarea, select { font-size: max(16px, 1em); }

  /* タッチフィードバック: タップ時のハイライトを有効化 */
  button, a { -webkit-tap-highlight-color: rgba(0,0,0,0.05); }

  /* 横向きタブレット: コンテンツを中央配置 */
  @media (orientation: landscape) and (max-height: 600px) {
    .min-h-\[80dvh\] { min-height: auto; padding-top: 1rem; padding-bottom: 1rem; }
  }
</style>

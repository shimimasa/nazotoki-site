---
/**
 * GM（進行役）用ページ — ネタバレ含む
 * 真相、GMガイド、解決編、学習ポイント
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllScenarios, type ScenarioData } from '../../lib/data';
import { getSeriesConfig } from '../../lib/series';
import { renderMarkdown } from '../../lib/markdown';
import curriculumData from '../../data/meta/curriculum.json';
import ClassroomBundleButton from '../../components/ClassroomBundleButton';

export function getStaticPaths() {
  const scenarios = loadAllScenarios();
  return scenarios.map(s => ({
    params: { slug: s.slug },
    props: { scenario: s },
  }));
}

const { scenario } = Astro.props as { scenario: ScenarioData };
const config = getSeriesConfig(scenario.series);
const scenarios = loadAllScenarios();
const truthHtml = renderMarkdown(scenario.truth);
const gmGuideHtml = renderMarkdown(scenario.gmGuide);
const solutionHtml = renderMarkdown(scenario.solution);
const learningHtml = renderMarkdown(scenario.learningGoals);
const curriculum: Record<string, any> = curriculumData;
const cur = curriculum[scenario.slug];

// 同じ学年のおすすめシナリオ（自分自身を除く、最大4件、別シリーズ優先）
const sameGradeScenarios = cur?.grade
  ? scenarios
      .filter(s => s.slug !== scenario.slug && curriculum[s.slug]?.grade === cur.grade)
      .sort((a, b) => {
        const aDiff = a.series !== scenario.series ? 0 : 1;
        const bDiff = b.series !== scenario.series ? 0 : 1;
        return aDiff - bDiff || a.volume - b.volume;
      })
      .slice(0, 4)
  : [];
---
<BaseLayout
  title={`GM用: ${scenario.title}`}
  description={`${scenario.title} のGM（進行役）向けページ`}
  noIndex={true}
  breadcrumbs={[
    { name: 'トップ', url: import.meta.env.BASE_URL },
    { name: scenario.seriesName, url: `${import.meta.env.BASE_URL}series/${scenario.series}/` },
    { name: scenario.title, url: `${import.meta.env.BASE_URL}play/${scenario.slug}/` },
    { name: 'GM用ページ' },
  ]}
>
  {/* パンくず */}
  <nav class="text-sm text-gray-500 mb-6 print:hidden">
    <a href={import.meta.env.BASE_URL} class="hover:text-gray-700">トップ</a>
    <span class="mx-1">/</span>
    <a href={`${import.meta.env.BASE_URL}series/${scenario.series}/`} class={`hover:${config.text}`}>{scenario.seriesName}</a>
    <span class="mx-1">/</span>
    <span>GM用: Vol.{scenario.volume}</span>
  </nav>

  {/* ネタバレ警告 */}
  <div class="bg-red-600 text-white rounded-xl p-6 mb-8 text-center">
    <p class="text-2xl font-black">⚠ ネタバレ注意</p>
    <p class="mt-2">このページにはシナリオの真相が書かれています。</p>
    <p class="text-sm mt-1 opacity-80">GM（進行役）のみ閲覧してください。プレイヤーは見ないでね！</p>
  </div>

  {/* ヘッダー */}
  <header class={`rounded-2xl bg-white border ${config.border} overflow-hidden mb-8 shadow-sm`}>
    <div class="p-6 sm:p-8">
      <div class={`flex gap-5 ${scenario.thumbnailUrl ? 'items-start' : ''}`}>
        {scenario.thumbnailUrl && (
          <img
            src={`${import.meta.env.BASE_URL}${scenario.thumbnailUrl.replace(/^\//, '')}`}
            alt={scenario.title}
            width="120"
            height="120"
            class="rounded-xl object-cover w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 shadow-sm"
          />
        )}
        <div class="min-w-0">
          <span class={`text-xs font-bold ${config.text} uppercase tracking-wide`}>
            {config.emoji} {scenario.seriesName} Vol.{scenario.volume} — GM用
          </span>
          <h1 class="text-3xl font-black mt-2">{scenario.title}</h1>
        </div>
      </div>
    </div>
    <div class={`border-t ${config.border} bg-white/60 px-6 sm:px-8 py-3 flex flex-wrap gap-x-6 gap-y-2 text-sm`}>
      <span class="flex items-center gap-1.5 text-gray-700"><span class="text-base">👥</span> {scenario.players.split('（')[0]}</span>
      <span class="flex items-center gap-1.5 text-gray-700"><span class="text-base">⏱</span> {scenario.time}</span>
      <span class="flex items-center gap-1.5 text-gray-700"><span class="text-base">📚</span> {scenario.subject}</span>
      <span class="text-gray-700">{scenario.difficulty}</span>
      {cur && (
        <span class="flex items-center gap-1.5">
          <span class="bg-amber-100 text-amber-800 font-bold rounded px-2 py-0.5 text-xs">{cur.grade}</span>
          <span class="text-gray-600">{cur.unit}</span>
        </span>
      )}
    </div>
  </header>

  {/* セッションモード — 目立つ位置に配置 */}
  <div class="bg-gradient-to-r from-amber-50 to-orange-50 rounded-xl border-2 border-amber-300 p-5 mb-8 print:hidden">
    <div class="flex items-center gap-4">
      <div class="flex-1">
        <h2 class="text-lg font-black text-amber-900">🎮 セッションモード</h2>
        <p class="text-sm text-amber-800 mt-1">
          タイマー付きのステップバイステップ進行。プロジェクター・タブレット対応。
        </p>
      </div>
      <a href={`${import.meta.env.BASE_URL}session/${scenario.slug}/`}
         class="inline-flex items-center gap-2 bg-amber-500 text-white px-5 py-3 rounded-xl font-bold hover:bg-amber-600 transition-colors no-underline text-sm whitespace-nowrap shadow-md">
        ▶ セッション開始
      </a>
    </div>
  </div>

  {/* 目次 */}
  <nav class="bg-white rounded-xl border border-gray-200 p-4 mb-8 print:hidden">
    <h2 class="font-bold text-sm text-gray-500 mb-2">このページの内容</h2>
    <ol class="text-sm space-y-1 list-decimal list-inside text-gray-700">
      <li><a href="#truth" class="hover:text-gray-900">事件の真相</a></li>
      <li><a href="#gm-guide" class="hover:text-gray-900">GMガイド（進行手順）</a></li>
      <li><a href="#solution" class="hover:text-gray-900">解決編（読み上げ台本）</a></li>
      {scenario.learningGoals && <li><a href="#learning" class="hover:text-gray-900">学習ポイント</a></li>}
      <li><a href="#gm-tools" class="hover:text-gray-900">GMツール（印刷・振り返り）</a></li>
    </ol>
  </nav>

  {/* 事件の真相 */}
  {scenario.truth && (
    <section id="truth" class="bg-white rounded-xl border-2 border-red-300 p-6 sm:p-8 mb-8">
      <h2 class="text-2xl font-black text-red-700 mb-4">🔓 事件の真相</h2>
      <div class="prose prose-lg max-w-none" set:html={truthHtml} />
    </section>
  )}

  {/* GMガイド */}
  <section id="gm-guide" class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8 mb-8">
    <h2 class="text-2xl font-black mb-4">📋 GMガイド</h2>
    <div class="prose max-w-none gm-content" set:html={gmGuideHtml} />
  </section>

  {/* 解決編 */}
  <section id="solution" class="bg-white rounded-xl border-2 border-amber-300 p-6 sm:p-8 mb-8">
    <h2 class="text-2xl font-black text-amber-800 mb-4">🎬 解決編</h2>
    <p class="text-sm text-gray-500 mb-4">投票後に、以下をプレイヤーに読み上げてください。</p>
    <div class="prose prose-lg max-w-none solution-content" set:html={solutionHtml} />
  </section>

  {/* 学習ポイント */}
  {scenario.learningGoals && (
    <section id="learning" class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8 mb-8">
      <h2 class="text-2xl font-black mb-4">📝 学習ポイント</h2>
      <div class="prose max-w-none" set:html={learningHtml} />
    </section>
  )}

  {/* GMツールセクション */}
  <section id="gm-tools" class="bg-white rounded-xl border-2 border-gray-300 p-6 sm:p-8 mb-8 print:hidden">
    <h2 class="text-2xl font-black mb-2">GMツール</h2>
    <p class="text-sm text-gray-500 mb-5">実施前の準備と実施後の振り返りに使えるツールです。</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {/* 実施前 */}
      <div class="rounded-lg border border-amber-200 bg-amber-50 p-4">
        <h3 class="font-bold text-amber-900 mb-2">実施前</h3>
        <a href={`${import.meta.env.BASE_URL}print/${scenario.slug}/`}
           class="flex items-center gap-2 bg-amber-600 text-white px-4 py-2.5 rounded-lg font-bold hover:bg-amber-700 transition-colors no-underline text-sm mb-2">
          <span class="text-lg">🖨</span> カード一式を印刷
        </a>
        <p class="text-xs text-amber-800">共通情報・キャラクターカード・証拠カードをA4で一括印刷できます。</p>
      </div>
      {/* 実施後 */}
      <div class="rounded-lg border border-green-200 bg-green-50 p-4">
        <h3 class="font-bold text-green-900 mb-2">実施後</h3>
        <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/reflect/`}
           class="flex items-center gap-2 bg-green-600 text-white px-4 py-2.5 rounded-lg font-bold hover:bg-green-700 transition-colors no-underline text-sm mb-2">
          <span class="text-lg">📝</span> 振り返りを記録
        </a>
        <div class="flex items-center gap-2 mt-2">
          <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/reflect-sheet/`}
             class="text-xs text-green-800 hover:text-green-900 font-bold underline">
            印刷用の振り返りシートはこちら
          </a>
        </div>
        <p class="text-xs text-green-800 mt-1">5分で記録。ブラウザに自動保存されます。</p>
      </div>
      {/* Phase 158: 授業資料 */}
      <div class="rounded-lg border border-blue-200 bg-blue-50 p-4">
        <h3 class="font-bold text-blue-900 mb-2">授業資料</h3>
        <ClassroomBundleButton
          client:load
          slug={scenario.slug}
          title={scenario.title}
          killerQuestions={scenario.killerQuestions || []}
        />
      </div>
    </div>
  </section>

  {/* === 同じ学年のおすすめ === */}
  {sameGradeScenarios.length > 0 && (
    <section class="mt-10 print:hidden">
      <h2 class="text-xl font-black text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 rounded-full bg-amber-400 inline-block"></span>
        {cur.grade}の他のシナリオ
      </h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {sameGradeScenarios.map(s => {
          const sc = getSeriesConfig(s.series);
          const sCur = curriculum[s.slug];
          return (
            <a href={`${import.meta.env.BASE_URL}gm/${s.slug}/`}
               class={`flex gap-3 items-center rounded-xl border ${sc.border} bg-white p-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline`}>
              {s.thumbnailUrl && (
                <img src={`${import.meta.env.BASE_URL}${s.thumbnailUrl.replace(/^\//, '')}`}
                     alt={`${s.title} サムネイル`} width="48" height="48"
                     class="rounded-lg object-cover w-12 h-12 flex-shrink-0" loading="lazy" />
              )}
              <div class="min-w-0 flex-1">
                <div class="font-bold text-gray-900 text-sm leading-snug line-clamp-1">{s.title}</div>
                <div class="flex items-center gap-2 mt-0.5 text-xs text-gray-500">
                  <span class={`font-bold ${sc.text}`}>{sc.emoji} {sc.name}</span>
                  {sCur?.unit && <span class="text-gray-400">{sCur.unit}</span>}
                </div>
              </div>
              <span class={`${sc.text} flex-shrink-0`}>&rarr;</span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {/* === F. プレイ後の導線 === */}
  <section class="mt-10 pt-8 border-t-2 border-gray-100 print:hidden">
    <h2 class="text-xl font-black text-gray-800 mb-4 text-center">次のステップ</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/reflect/`}
         class="flex flex-col items-center gap-2 rounded-xl border border-green-200 bg-white p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">📝</span>
        <span class="font-bold text-green-800 text-sm">振り返りを記録</span>
        <span class="text-xs text-green-600">5分で記録、次回に活かす</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}series/${scenario.series}/`}
         class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">{config.emoji}</span>
        <span class="font-bold text-gray-800 text-sm">次のシナリオを選ぶ</span>
        <span class="text-xs text-gray-500">{scenario.seriesName}</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}guide/#gm`}
         class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">📘</span>
        <span class="font-bold text-gray-800 text-sm">GMのコツを見る</span>
        <span class="text-xs text-gray-500">進行のポイント解説</span>
      </a>
      <a href={import.meta.env.BASE_URL}
         class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">🔍</span>
        <span class="font-bold text-gray-800 text-sm">他の教科を見る</span>
        <span class="text-xs text-gray-500">全6シリーズ・100シナリオ</span>
      </a>
    </div>
  </section>

  {/* 操作ボタン */}
  <div class="flex flex-wrap gap-3 justify-center mt-6 print:hidden">
    <a href={`${import.meta.env.BASE_URL}play/${scenario.slug}/`}
       class="inline-block bg-gray-100 text-gray-700 px-5 py-2.5 rounded-xl font-bold hover:bg-gray-200 transition-colors no-underline text-sm">
      ← プレイヤーページへ
    </a>
    <button onclick="window.print()"
            class="bg-gray-800 text-white px-5 py-2.5 rounded-xl font-bold hover:bg-gray-700 transition-colors text-sm">
      このページを印刷する
    </button>
  </div>
</BaseLayout>

<style>
  .gm-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 900;
    margin-top: 2rem;
    padding-bottom: 0.25rem;
    border-bottom: 2px solid #e5e7eb;
  }
  .gm-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 1.5rem;
  }
  .solution-content :global(h1) {
    font-size: 2rem;
    font-weight: 900;
    text-align: center;
    color: #92400e;
  }
  .solution-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 900;
    margin-top: 1.5rem;
  }
</style>

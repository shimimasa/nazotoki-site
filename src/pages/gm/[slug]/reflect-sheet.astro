---
/**
 * 振り返り印刷用シート — A4 1枚の手書き記入テンプレート
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReflectionPrintSheet from '../../../components/ReflectionPrintSheet.astro';
import { loadAllScenarios, type ScenarioData } from '../../../lib/data';
import { getSeriesConfig } from '../../../lib/series';

export function getStaticPaths() {
  const scenarios = loadAllScenarios();
  return scenarios.map(s => ({
    params: { slug: s.slug },
    props: { scenario: s },
  }));
}

const { scenario } = Astro.props as { scenario: ScenarioData };
const config = getSeriesConfig(scenario.series);
---
<BaseLayout
  title={`振り返りシート: ${scenario.title}`}
  description={`${scenario.title} の振り返り印刷用シート`}
  noIndex={true}
>
  {/* 画面表示: 操作エリア */}
  <div class="print:hidden mb-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href={import.meta.env.BASE_URL} class="hover:text-gray-700">トップ</a>
      <span class="mx-1">/</span>
      <a href={`${import.meta.env.BASE_URL}series/${scenario.series}/`} class={`hover:${config.text}`}>{scenario.seriesName}</a>
      <span class="mx-1">/</span>
      <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/`} class="hover:text-gray-700">GM用</a>
      <span class="mx-1">/</span>
      <span>振り返りシート（印刷用）</span>
    </nav>

    <div class={`rounded-xl ${config.bgLight} border-2 ${config.border} p-6 mb-6`}>
      <span class={`text-xs font-bold ${config.text}`}>
        {config.emoji} {scenario.seriesName} Vol.{scenario.volume}
      </span>
      <h1 class="text-2xl font-black mt-2">振り返りシート（印刷用）</h1>
      <p class="text-gray-600 mt-1">{scenario.title}</p>
    </div>

    <p class="text-sm text-gray-600 mb-4">
      A4用紙1枚に収まる手書き用シートです。プレイ後に配布するか、GM自身の記録にお使いください。
    </p>

    <div class="flex flex-wrap gap-3 mb-8">
      <button onclick="window.print()"
              class="bg-gray-800 text-white px-6 py-3 rounded-lg font-bold hover:bg-gray-700 transition-colors">
        印刷する
      </button>
      <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/reflect/`}
         class="inline-flex items-center bg-gray-200 text-gray-800 px-5 py-3 rounded-lg font-bold hover:bg-gray-300 transition-colors no-underline text-sm">
        デジタル記録へ
      </a>
      <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/`}
         class="inline-flex items-center bg-gray-200 text-gray-800 px-5 py-3 rounded-lg font-bold hover:bg-gray-300 transition-colors no-underline text-sm">
        &larr; GMページに戻る
      </a>
    </div>
  </div>

  {/* 印刷コンテンツ */}
  <ReflectionPrintSheet
    title={scenario.title}
    seriesName={scenario.seriesName}
    volume={scenario.volume}
    subject={scenario.subject}
    players={scenario.players}
    time={scenario.time}
  />
</BaseLayout>

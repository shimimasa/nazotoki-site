---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAllScenarios } from '../lib/data';
import type { CurriculumMap, RecommendationsData } from '../lib/data-types';
import { SERIES_CONFIG, getSeriesConfig } from '../lib/series';
import curriculumData from '../data/meta/curriculum.json';
import recommendationsData from '../data/meta/recommendations.json';

const scenarios = loadAllScenarios();
const curriculum: CurriculumMap = curriculumData;
const recommendations: RecommendationsData = recommendationsData;

// シリーズ別にグループ化
const seriesGroups = new Map<string, typeof scenarios>();
for (const s of scenarios) {
  if (!seriesGroups.has(s.series)) seriesGroups.set(s.series, []);
  seriesGroups.get(s.series)!.push(s);
}

// おすすめシナリオ取得ヘルパー
function getScenarioBySlug(slug: string) {
  return scenarios.find(s => s.slug === slug);
}

// ペルソナ別おすすめデータ
const personas = recommendations.personas.map((p) => ({
  ...p,
  scenarioData: p.scenarios.map((slug: string) => getScenarioBySlug(slug)).filter(Boolean),
}));

// おすすめシナリオ（フィルタ初期表示用）
const featuredScenarios = recommendations.featured
  .map((slug: string) => getScenarioBySlug(slug))
  .filter(Boolean);

// ラベル情報
const labels: Record<string, string[]> = recommendations.labels;

// シリーズ比較データ
const seriesComparison = recommendations.seriesComparison;

// フィルタ用データ
const filterData = scenarios.map(s => {
  const cur = curriculum[s.slug];
  return {
    slug: s.slug,
    title: s.title,
    series: s.series,
    volume: s.volume,
    grade: cur?.grade || '',
    unit: cur?.unit || '',
    difficulty: s.difficulty,
    players: s.players.split('\uFF08')[0],
    time: s.time,
    synopsis: s.synopsis.split('\n')[0],
    thumbnailUrl: s.thumbnailUrl || '',
    labels: labels[s.slug] || [],
  };
});

const seriesOptions = Object.entries(SERIES_CONFIG).map(([key, c]) => ({
  key,
  name: c.name,
  emoji: c.emoji,
}));

const PERSONA_COLORS: Record<string, { bg: string; border: string; text: string; bgLight: string }> = {
  amber: { bg: 'bg-amber-500', border: 'border-amber-300', text: 'text-amber-800', bgLight: 'bg-amber-50' },
  blue: { bg: 'bg-blue-500', border: 'border-blue-300', text: 'text-blue-800', bgLight: 'bg-blue-50' },
  green: { bg: 'bg-green-500', border: 'border-green-300', text: 'text-green-800', bgLight: 'bg-green-50' },
};

---
<BaseLayout title="ナゾトキ探偵団" fullWidth ogImage="og/top.png">

  {/* ============================================
       HERO
     ============================================ */}
  <section class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="max-w-5xl mx-auto px-4 py-16 sm:py-24 text-center">
      <h1 class="text-3xl sm:text-5xl font-black tracking-tight leading-tight">
        教科の知識で、謎を解け。
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-slate-300">
        小学生から使える教育マーダーミステリー
      </p>
      <p class="mt-2 text-sm text-slate-400">
        全{scenarios.length}シナリオ、すべて無料
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#search-section"
           data-goatcounter-click="hero-cta-search"
           class="inline-flex items-center justify-center bg-amber-500 hover:bg-amber-600 text-white font-bold px-8 py-3.5 rounded-lg shadow-lg hover:shadow-xl transition-all no-underline">
          シナリオを探す
        </a>
        <a href={`${import.meta.env.BASE_URL}guide/`}
           data-goatcounter-click="hero-cta-guide"
           class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-3.5 rounded-lg border border-white/20 transition-all no-underline">
          遊び方を見る
        </a>
      </div>
      <p class="mt-6 text-sm text-slate-400">
        現役教員が設計。家庭でも授業でも使えます
      </p>
    </div>
  </section>

  {/* ============================================
       3つの特徴
     ============================================ */}
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid gap-8 sm:grid-cols-3 text-center">
        <div>
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-amber-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-800">教科 x 推理</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">5教科の知識を使って事件を解決。<br class="hidden sm:inline" />遊びながら教科の理解が深まります</p>
        </div>
        <div>
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-emerald-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-800">完全無料</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">全シナリオ、準備から利用まですべて無料。<br class="hidden sm:inline" />登録も不要です</p>
        </div>
        <div>
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-blue-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-800">45分で完結</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">1授業分で遊べる設計。<br class="hidden sm:inline" />調査・議論・推理発表の3ステップ</p>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================
       遊び方（ソロ + グループ）
     ============================================ */}
  <section class="bg-slate-50 py-10">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-indigo-200 bg-gradient-to-r from-indigo-50 to-white p-5">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-2xl">🔍</span>
            <h3 class="text-base font-bold text-indigo-900">ソロモード</h3>
          </div>
          <p class="text-sm text-indigo-700 leading-relaxed">1人で全シナリオをプレイ可能。証拠を調べ、推理して犯人を当てよう</p>
        </div>
        <div class="rounded-xl border border-amber-200 bg-gradient-to-r from-amber-50 to-white p-5">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-2xl">🎮</span>
            <h3 class="text-base font-bold text-amber-900">セッションモード</h3>
          </div>
          <p class="text-sm text-amber-700 leading-relaxed">先生やGMが進行。教室30人でもグループ4人でも。準備10分・プレイ45分</p>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================
       教科シリーズ（6枚 + 全シリーズリンク）
     ============================================ */}
  <section class="bg-slate-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-800 mb-8">18の教科シリーズ</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {seriesComparison.slice(0, 6).map((comp) => {
          const config = getSeriesConfig(comp.series);
          const count = seriesGroups.get(comp.series)?.length || 0;
          return (
            <a href={`${import.meta.env.BASE_URL}series/${comp.series}/`}
               class={`block rounded-xl border ${config.border} bg-white p-5 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all no-underline group`}>
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">{config.emoji}</span>
                <h3 class={`text-lg font-bold ${config.text}`}>{config.name}</h3>
              </div>
              <p class="text-sm text-slate-600 mb-2">{comp.highlight}</p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400">{count}シナリオ</span>
                <span class={`text-sm font-bold ${config.text} group-hover:translate-x-1 transition-transform`}>&rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        {seriesComparison.slice(6).map((comp) => {
          const config = getSeriesConfig(comp.series);
          return (
            <a href={`${import.meta.env.BASE_URL}series/${comp.series}/`}
               class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-slate-200 bg-white text-sm text-slate-600 hover:shadow-md hover:border-slate-300 transition-all no-underline">
              <span>{config.emoji}</span>
              <span class="font-bold">{config.name}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {/* ============================================
       こんな方におすすめ
     ============================================ */}
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-800 mb-8">こんな方におすすめ</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {personas.map((p) => {
          const colors = PERSONA_COLORS[p.color] || PERSONA_COLORS.amber;
          return (
            <div class={`rounded-xl border ${colors.border} bg-white p-5 shadow-sm`}>
              <div class="text-3xl mb-2">{p.emoji}</div>
              <h3 class={`text-lg font-bold ${colors.text}`}>{p.title}</h3>
              <p class="text-sm text-slate-600 mt-2 leading-relaxed">{p.description}</p>
              <div class="mt-4 space-y-2">
                {p.scenarioData.slice(0, 3).map((s) => {
                  const sc = getSeriesConfig(s.series);
                  return (
                    <a href={`${import.meta.env.BASE_URL}play/${s.slug}/`}
                       class="flex items-center gap-2 bg-white rounded-lg px-3 py-2 text-sm no-underline hover:shadow-md transition-shadow border border-gray-100">
                      <span class={`font-bold ${sc.text}`}>{sc.emoji}</span>
                      <span class="font-bold text-slate-800 truncate">{s.title}</span>
                      <span class="ml-auto text-slate-300 flex-shrink-0">&#8250;</span>
                    </a>
                  );
                })}
              </div>
              {p.link && (
                <a href={`${import.meta.env.BASE_URL}${p.link}`}
                   class={`block mt-3 text-center text-sm font-bold ${colors.text} hover:underline no-underline`}>
                  詳しく見る →
                </a>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* ============================================
       シナリオ検索
     ============================================ */}
  <section class="bg-slate-50 py-14" id="search-section">
    <div class="max-w-5xl mx-auto px-4">
      <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-800 mb-4">シナリオを探す</h2>

        {/* フィルタ行 */}
        <div class="flex flex-wrap gap-3 mb-4">
          <select id="filter-series" class="border border-slate-300 rounded-lg px-3 py-2 text-sm bg-white">
            <option value="">すべての教科</option>
            {seriesOptions.map(s => (
              <option value={s.key}>{s.emoji} {s.name}</option>
            ))}
          </select>
          <select id="filter-grade" class="border border-slate-300 rounded-lg px-3 py-2 text-sm bg-white">
            <option value="">先に教科を選択</option>
          </select>
          <input
            type="text"
            id="filter-keyword"
            placeholder="タイトル・単元で検索..."
            class="border border-slate-300 rounded-lg px-3 py-2 text-sm flex-1 min-w-[180px]"
          />
        </div>

        {/* おすすめ表示（フィルタ未選択時） */}
        <div id="filter-featured">
          <p class="text-sm text-slate-500 mb-3">おすすめシナリオ</p>
          <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3" id="featured-grid">
        {featuredScenarios.map((s) => {
              const sc = getSeriesConfig(s.series);
              const cur = curriculum[s.slug];
              const slugLabels = labels[s.slug] || [];
              return (
                <a href={`${import.meta.env.BASE_URL}play/${s.slug}/`}
                   class="flex gap-2.5 items-center rounded-lg border border-slate-200 px-3 py-2.5 hover:shadow-md hover:border-slate-300 transition-all no-underline bg-white">
                  {s.thumbnailUrl && (
                    <img src={`${import.meta.env.BASE_URL}${s.thumbnailUrl.replace(/^\//, '')}`}
                         alt={`${s.title} サムネイル`} width="48" height="48"
                         class="rounded object-cover w-12 h-12 flex-shrink-0" loading="lazy" />
                  )}
                  <div class="min-w-0 flex-1">
                    <div class="font-bold text-slate-900 text-sm leading-snug line-clamp-1">{s.title}</div>
                    <div class="flex items-center gap-2 mt-0.5 text-xs text-slate-400">
                      <span class={`font-bold ${sc.text}`}>{sc.emoji} Vol.{s.volume}</span>
                      {cur?.grade && <span class="text-amber-700">{cur.grade}</span>}
                      {slugLabels.includes('初心者向け') && (
                        <span class="bg-green-100 text-green-700 px-1.5 py-0.5 rounded text-[10px] font-bold">初心者向け</span>
                      )}
                    </div>
                  </div>
                  <span class="text-slate-300 text-sm flex-shrink-0">&#8250;</span>
                </a>
              );
            })}
          </div>
          <p class="text-xs text-slate-400 mt-3 text-center">教科や学年で絞り込むと、全{scenarios.length}シナリオから検索できます</p>
        </div>

        {/* 件数 */}
        <p id="filter-count" class="text-sm text-slate-500 mb-3 hidden"></p>

        {/* 結果グリッド */}
        <div id="filter-results" class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3 hidden"></div>

        {/* もっと見るボタン */}
        <div id="filter-more-wrap" class="hidden text-center mt-4">
          <button id="filter-more-btn" class="text-sm text-amber-600 font-bold hover:text-amber-700 px-4 py-2 border border-amber-300 rounded-lg hover:bg-amber-50 transition-colors">
          </button>
        </div>

        {/* 空結果 */}
        <p id="filter-empty" class="hidden text-center text-slate-400 py-8">
          条件に一致するシナリオが見つかりませんでした。<br/>
          <button id="filter-reset" class="text-amber-600 font-bold hover:text-amber-700 mt-2">条件をリセット</button>
        </p>
      </div>
    </div>
  </section>

  {/* ============================================
       信頼・実績
     ============================================ */}
  <section class="bg-slate-900 text-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid gap-8 sm:grid-cols-4 text-center mb-10">
        <div>
          <div class="text-4xl font-black">{scenarios.length}</div>
          <div class="text-sm text-slate-400 mt-1">シナリオ数</div>
        </div>
        <div>
          <div class="text-4xl font-black">51名</div>
          <div class="text-sm text-slate-400 mt-1">テストプレイ参加</div>
        </div>
        <div>
          <div class="text-4xl font-black">18教科</div>
          <div class="text-sm text-slate-400 mt-1">カリキュラム対応</div>
        </div>
        <div>
          <div class="text-4xl font-black">45分</div>
          <div class="text-sm text-slate-400 mt-1">1授業で完結</div>
        </div>
      </div>
      <blockquote class="max-w-2xl mx-auto text-center">
        <p class="text-lg text-slate-300 italic leading-relaxed">
          「正解のない問いに、全員が本気で考えていた」
        </p>
        <cite class="block mt-3 text-sm text-slate-500 not-italic">
          &mdash; 小学校でのテストプレイより（51名参加・3回実施）
        </cite>
      </blockquote>
    </div>
  </section>

  {/* ============================================
       よくある質問
     ============================================ */}
  <section class="bg-white py-14" id="faq-section">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-800 mb-8 text-center">よくある質問</h2>
      <div class="grid gap-x-8 gap-y-0 sm:grid-cols-2 max-w-4xl mx-auto">
        <details class="group border-b border-slate-100 py-4" open>
          <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-slate-800 text-sm leading-relaxed">
            マーダーミステリーって何ですか？
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">
            参加者がそれぞれ登場人物になりきり、会話と推理で謎を解くゲームです。
            ナゾトキ探偵団では「犯人探し」ではなく「教科の知識を使った謎解き」を中心にしているため、
            子どもでも安心して楽しめます。
          </p>
        </details>
        <details class="group border-b border-slate-100 py-4">
          <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-slate-800 text-sm leading-relaxed">
            子どもに暴力的な内容はありませんか？
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">
            ありません。全シナリオで暴力・流血・死亡の直接描写を排除しています。
            「事件」は「謎の失踪」「不思議な現象」などに置き換え、小学生でも安心して遊べる設計です。
            現役教員が全シナリオを監修しています。
          </p>
        </details>
        <details class="group border-b border-slate-100 py-4">
          <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-slate-800 text-sm leading-relaxed">
            準備にどれくらいかかりますか？
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">
            GM（進行役）がGMページで真相を読むのに約10分。
            あとはプレイヤーにURLを共有するか、キャラクターシートを印刷するだけです。
            特別な道具や購入は一切不要です。
          </p>
        </details>
        <details class="group border-b border-slate-100 py-4">
          <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-slate-800 text-sm leading-relaxed">
            1人でも遊べますか？
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">
            はい、<strong>ソロモード</strong>を使えば1人で全シナリオをプレイできます。
            GMなしで証言を読み、証拠を調べ、推理して投票する「探偵ファイル」形式です。
            シナリオ詳細ページの「ソロモードで推理する」ボタンから始められます。
            もちろん2〜4人＋GMでのグループプレイや、教室での集団プレイ（30人対応）にも対応しています。
          </p>
        </details>
        <details class="group border-b border-slate-100 py-4">
          <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-slate-800 text-sm leading-relaxed">
            授業で使っても大丈夫ですか？
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">
            はい、授業での利用を歓迎します。全シナリオ無料で、学習指導要領に対応した単元情報も掲載しています。
            45分授業に収まる設計で、教員向けの授業進行ガイドもご用意しています。
          </p>
        </details>
        <details class="group border-b border-slate-100 py-4">
          <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-slate-800 text-sm leading-relaxed">
            印刷は必要ですか？
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">
            印刷なしでも遊べます。各プレイヤーにスマホやタブレットがあれば、URLを共有するだけで参加できます。
            印刷して遊びたい場合は、印刷用ページからワンクリックで出力できます。
          </p>
        </details>
      </div>
    </div>
  </section>

  {/* ============================================
       最終CTA + 今日のナゾトキ
     ============================================ */}
  <section class="bg-gradient-to-br from-slate-800 to-slate-900 text-white py-16">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="text-2xl sm:text-3xl font-bold tracking-tight">考える力を、遊びから。</p>
      <p class="mt-3 text-slate-400">全{scenarios.length}シナリオ、すべて無料でご利用いただけます</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#search-section"
           data-goatcounter-click="footer-cta-search"
           class="inline-flex items-center justify-center bg-amber-500 hover:bg-amber-600 text-white font-bold px-8 py-3.5 rounded-lg shadow-lg hover:shadow-xl transition-all no-underline">
          無料でシナリオを見る
        </a>
        <a href={`${import.meta.env.BASE_URL}challenge/`}
           data-goatcounter-click="footer-cta-challenge"
           class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-3.5 rounded-lg border border-white/20 transition-all no-underline">
          今日のナゾトキに挑戦
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script define:vars={{ filterData }}>
  const BASE = document.querySelector('link[rel="canonical"]')?.href.replace(/[^/]*$/, '') || '/';
  const PAGE_SIZE = 12;
  let visibleCount = PAGE_SIZE;

  const SERIES_COLORS = {
    'time-travel': { emoji: '🕰️', color: '#92400e' },
    'literature': { emoji: '📖', color: '#3730a3' },
    'popculture': { emoji: '🎭', color: '#6b21a8' },
    'math': { emoji: '🔢', color: '#065f46' },
    'science': { emoji: '🔬', color: '#1e40af' },
    'moral': { emoji: '⚖️', color: '#9a3412' },
    'digital': { emoji: '💻', color: '#0e7490' },
    'geography': { emoji: '🗺️', color: '#0d9488' },
    'health': { emoji: '🏥', color: '#e11d48' },
    'english': { emoji: '🔤', color: '#0284c7' },
    'career': { emoji: '💼', color: '#65a30d' },
    'esd': { emoji: '🌍', color: '#16a34a' },
    'civics': { emoji: '🏛️', color: '#475569' },
    'disaster': { emoji: '🚨', color: '#dc2626' },
    'homeec': { emoji: '🧵', color: '#db2777' },
    'money': { emoji: '💰', color: '#ca8a04' },
    'programming': { emoji: '🖥️', color: '#7c3aed' },
    'math2': { emoji: '📐', color: '#047857' },
  };

  const elSeries = document.getElementById('filter-series');
  const elGrade = document.getElementById('filter-grade');
  const elKeyword = document.getElementById('filter-keyword');
  const elResults = document.getElementById('filter-results');
  const elCount = document.getElementById('filter-count');
  const elEmpty = document.getElementById('filter-empty');
  const elFeatured = document.getElementById('filter-featured');
  const elMoreWrap = document.getElementById('filter-more-wrap');
  const elMoreBtn = document.getElementById('filter-more-btn');
  const elReset = document.getElementById('filter-reset');

  function gradeNum(g) {
    const m = g.match(/小(\d)/);
    if (m) return parseInt(m[1]);
    const m2 = g.match(/中(\d)/);
    if (m2) return parseInt(m2[1]) + 6;
    if (g.includes('中')) return 7;
    return 99;
  }

  function updateGradeOptions() {
    const series = elSeries.value;
    const subset = series ? filterData.filter(s => s.series === series) : filterData;
    const gradeSet = new Set();
    for (const s of subset) {
      if (s.grade) gradeSet.add(s.grade);
    }
    const grades = [...gradeSet].sort((a, b) => gradeNum(a) - gradeNum(b));
    const prev = elGrade.value;
    const gradeLabel = series ? 'すべての学年' : '先に教科を選択';
    elGrade.innerHTML = `<option value="">${gradeLabel}</option>`;
    for (const g of grades) {
      const opt = document.createElement('option');
      opt.value = g;
      opt.textContent = g;
      if (g === prev) opt.selected = true;
      elGrade.appendChild(opt);
    }
  }

  function isFilterActive() {
    return elSeries.value || elGrade.value || elKeyword.value.trim();
  }

  function getFiltered() {
    const series = elSeries.value;
    const grade = elGrade.value;
    const keyword = elKeyword.value.trim().toLowerCase();
    return filterData.filter(s => {
      if (series && s.series !== series) return false;
      if (grade && !s.grade.includes(grade)) return false;
      if (keyword && !s.title.toLowerCase().includes(keyword) && !s.unit.toLowerCase().includes(keyword)) return false;
      return true;
    });
  }

  function renderCard(s) {
    const c = SERIES_COLORS[s.series] || SERIES_COLORS['time-travel'];
    const thumb = s.thumbnailUrl
      ? `<img src="${BASE}${s.thumbnailUrl.replace(/^\//, '')}" alt="" width="48" height="48" class="rounded object-cover w-12 h-12 flex-shrink-0" loading="lazy" />`
      : '';
    const gradeBadge = s.grade
      ? `<span class="text-xs text-amber-700">${s.grade}</span>`
      : '';
    const labelBadges = (s.labels || []).map(l => {
      if (l === '初心者向け') return `<span class="bg-green-100 text-green-700 px-1.5 py-0.5 rounded text-[10px] font-bold">初心者向け</span>`;
      if (l === 'テストプレイ済み') return `<span class="bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded text-[10px] font-bold">実証済み</span>`;
      return '';
    }).filter(Boolean).join('');
    return `
      <a href="${BASE}play/${s.slug}/" class="flex gap-2.5 items-center rounded-lg border border-slate-200 px-3 py-2.5 hover:shadow-md hover:border-slate-300 transition-all no-underline bg-white">
        ${thumb}
        <div class="min-w-0 flex-1">
          <div class="font-bold text-slate-900 text-sm leading-snug line-clamp-1">${s.title}</div>
          <div class="flex items-center gap-2 mt-0.5 text-xs text-slate-400 flex-wrap">
            <span style="color:${c.color}" class="font-bold">${c.emoji} Vol.${s.volume}</span>
            ${gradeBadge}
            <span>${s.difficulty}</span>
            ${labelBadges}
          </div>
        </div>
        <span class="text-slate-300 text-sm flex-shrink-0">&#8250;</span>
      </a>
    `;
  }

  function renderResults() {
    const active = isFilterActive();

    elFeatured.classList.toggle('hidden', active);
    elCount.classList.toggle('hidden', !active);
    elResults.classList.toggle('hidden', !active);

    if (!active) {
      elResults.innerHTML = '';
      elEmpty.classList.add('hidden');
      elMoreWrap.classList.add('hidden');
      return;
    }

    const filtered = getFiltered();
    elCount.textContent = `${filtered.length}件のシナリオ`;
    elEmpty.classList.toggle('hidden', filtered.length > 0);

    const showing = filtered.slice(0, visibleCount);
    elResults.innerHTML = showing.map(renderCard).join('');

    const remaining = filtered.length - visibleCount;
    if (remaining > 0) {
      elMoreWrap.classList.remove('hidden');
      elMoreBtn.textContent = `さらに${Math.min(remaining, PAGE_SIZE)}件を表示（残り${remaining}件）`;
    } else {
      elMoreWrap.classList.add('hidden');
    }
  }

  function resetFilters() {
    elSeries.value = '';
    elGrade.value = '';
    elKeyword.value = '';
    updateGradeOptions();
    visibleCount = PAGE_SIZE;
    renderResults();
  }

  elSeries.addEventListener('change', () => {
    updateGradeOptions();
    visibleCount = PAGE_SIZE;
    renderResults();
  });
  elGrade.addEventListener('change', () => {
    visibleCount = PAGE_SIZE;
    renderResults();
  });
  elKeyword.addEventListener('input', () => {
    visibleCount = PAGE_SIZE;
    renderResults();
  });
  elMoreBtn.addEventListener('click', () => {
    visibleCount += PAGE_SIZE;
    renderResults();
  });
  elReset.addEventListener('click', resetFilters);

  updateGradeOptions();
  renderResults();
</script>

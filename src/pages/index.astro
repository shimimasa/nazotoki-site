---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAllScenarios } from '../lib/data';
import { SERIES_CONFIG, getSeriesConfig } from '../lib/series';
import curriculumData from '../data/meta/curriculum.json';

const scenarios = loadAllScenarios();
const curriculum: Record<string, any> = curriculumData;

// シリーズ別にグループ化
const seriesGroups = new Map<string, typeof scenarios>();
for (const s of scenarios) {
  if (!seriesGroups.has(s.series)) seriesGroups.set(s.series, []);
  seriesGroups.get(s.series)!.push(s);
}

// シリーズ順でソート
const orderedSeries = [...seriesGroups.entries()].sort((a, b) => {
  const orderA = SERIES_CONFIG[a[0]]?.emoji ? Object.keys(SERIES_CONFIG).indexOf(a[0]) : 99;
  const orderB = SERIES_CONFIG[b[0]]?.emoji ? Object.keys(SERIES_CONFIG).indexOf(b[0]) : 99;
  return orderA - orderB;
});

// フィルタ用データ
const filterData = scenarios.map(s => {
  const cur = curriculum[s.slug];
  return {
    slug: s.slug,
    title: s.title,
    series: s.series,
    volume: s.volume,
    grade: cur?.grade || '',
    unit: cur?.unit || '',
    difficulty: s.difficulty,
    players: s.players.split('（')[0],
    time: s.time,
    synopsis: s.synopsis.split('\n')[0],
    thumbnailUrl: s.thumbnailUrl || '',
  };
});

const seriesOptions = Object.entries(SERIES_CONFIG).map(([key, c]) => ({
  key,
  name: c.name,
  emoji: c.emoji,
}));
---
<BaseLayout title="ナゾトキ探偵団">
  <div class="text-center mb-10">
    <h1 class="text-4xl sm:text-5xl font-black tracking-tight">
      <span class="text-amber-600">🔍</span> ナゾトキ探偵団
    </h1>
    <p class="mt-3 text-lg text-gray-600">AIが作り、人間が考える — 教育マダミス</p>
    <p class="mt-2 text-sm text-gray-500">全{scenarios.length}シナリオ 無料配布中</p>
    <a href={`${import.meta.env.BASE_URL}guide/`} class="inline-block mt-3 text-sm text-amber-600 font-bold hover:text-amber-700 no-underline">📘 はじめての方はこちら →</a>
  </div>

  {/* シリーズカード */}
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-12">
    {orderedSeries.map(([series, items]) => {
      const config = getSeriesConfig(series);
      return (
        <a href={`${import.meta.env.BASE_URL}series/${series}/`}
           class={`block rounded-xl border-2 ${config.border} ${config.bgLight} p-6 hover:shadow-lg transition-shadow no-underline group`}>
          <div class="text-3xl mb-2">{config.emoji}</div>
          <h2 class={`text-xl font-black ${config.text}`}>{config.name}</h2>
          <p class="text-sm text-gray-600 mt-1">{config.subject}</p>
          <div class="mt-3 flex items-center justify-between">
            <span class="text-sm text-gray-500">{items.length}シナリオ</span>
            <span class={`text-sm font-bold ${config.text} group-hover:translate-x-1 transition-transform`}>&rarr;</span>
          </div>
        </a>
      );
    })}
  </div>

  {/* シナリオ検索フィルタ */}
  <section class="bg-white rounded-xl border border-gray-200 p-6 mb-8" id="search-section">
    <h2 class="text-2xl font-black mb-4">シナリオを探す</h2>

    {/* フィルタ行 */}
    <div class="flex flex-wrap gap-3 mb-4">
      <select id="filter-series" class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white">
        <option value="">すべての教科</option>
        {seriesOptions.map(s => (
          <option value={s.key}>{s.emoji} {s.name}</option>
        ))}
      </select>
      <select id="filter-grade" class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white">
        <option value="">すべての学年</option>
      </select>
      <input
        type="text"
        id="filter-keyword"
        placeholder="タイトル・単元で検索..."
        class="border border-gray-300 rounded-lg px-3 py-2 text-sm flex-1 min-w-[180px]"
      />
    </div>

    {/* 初期メッセージ（フィルタ未選択時） */}
    <div id="filter-prompt" class="text-center py-6 text-gray-400">
      <p class="text-sm">教科や学年を選ぶと、シナリオが表示されます</p>
    </div>

    {/* 件数 */}
    <p id="filter-count" class="text-sm text-gray-500 mb-3 hidden"></p>

    {/* 結果グリッド */}
    <div id="filter-results" class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3"></div>

    {/* もっと見るボタン */}
    <div id="filter-more-wrap" class="hidden text-center mt-4">
      <button id="filter-more-btn" class="text-sm text-amber-600 font-bold hover:text-amber-700 px-4 py-2 border border-amber-300 rounded-lg hover:bg-amber-50 transition-colors">
      </button>
    </div>

    {/* 空結果 */}
    <p id="filter-empty" class="hidden text-center text-gray-400 py-8">条件に一致するシナリオが見つかりませんでした</p>
  </section>

  {/* はじめてガイド */}
  <section class="grid gap-4 sm:grid-cols-3">
    <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-5 text-center">
      <div class="text-3xl mb-2">1</div>
      <h3 class="font-black text-amber-900">シナリオを選ぶ</h3>
      <p class="text-sm text-gray-600 mt-2">教科と学年で絞り込み、シナリオを決定</p>
    </div>
    <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-5 text-center">
      <div class="text-3xl mb-2">2</div>
      <h3 class="font-black text-amber-900">GM（進行役）が準備</h3>
      <p class="text-sm text-gray-600 mt-2">GMページで真相を確認。カードを印刷 or URLを共有</p>
    </div>
    <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-5 text-center">
      <div class="text-3xl mb-2">3</div>
      <h3 class="font-black text-amber-900">30〜45分で完結</h3>
      <p class="text-sm text-gray-600 mt-2">調査 → 議論 → 推理発表。教科の知識で謎を解く！</p>
    </div>
  </section>

  <section class="mt-8 bg-white rounded-xl border border-gray-200 p-6 sm:p-8">
    <h2 class="text-2xl font-black mb-4">ナゾトキ探偵団とは？</h2>
    <div class="prose max-w-none text-gray-700">
      <p>
        「ナゾトキ探偵団」は、<strong>教科の知識を使って謎を解く</strong>教育マダミス（マーダーミステリー）シリーズです。
        歴史・国語・算数・理科・道徳の5教科をカバーし、遊びながら教科の理解を深められます。
      </p>
      <p>
        すべてのシナリオは<strong>完全無料</strong>。ご家庭での親子プレイから、学校の授業まで幅広くお使いいただけます。
      </p>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ filterData }}>
  const BASE = document.querySelector('link[rel="canonical"]')?.href.replace(/[^/]*$/, '') || '/';
  const PAGE_SIZE = 12;
  let visibleCount = PAGE_SIZE;

  const SERIES_COLORS = {
    'time-travel': { emoji: '🕰️', color: '#92400e' },
    'literature': { emoji: '📖', color: '#3730a3' },
    'popculture': { emoji: '🎭', color: '#6b21a8' },
    'math': { emoji: '🔢', color: '#065f46' },
    'science': { emoji: '🔬', color: '#1e40af' },
    'moral': { emoji: '⚖️', color: '#9a3412' },
  };

  const elSeries = document.getElementById('filter-series');
  const elGrade = document.getElementById('filter-grade');
  const elKeyword = document.getElementById('filter-keyword');
  const elResults = document.getElementById('filter-results');
  const elCount = document.getElementById('filter-count');
  const elEmpty = document.getElementById('filter-empty');
  const elPrompt = document.getElementById('filter-prompt');
  const elMoreWrap = document.getElementById('filter-more-wrap');
  const elMoreBtn = document.getElementById('filter-more-btn');

  // 学年ソート用
  function gradeNum(g) {
    const m = g.match(/小(\d)/);
    if (m) return parseInt(m[1]);
    const m2 = g.match(/中(\d)/);
    if (m2) return parseInt(m2[1]) + 6;
    if (g.includes('中')) return 7;
    return 99;
  }

  // 教科選択に連動して学年ドロップダウンを更新
  function updateGradeOptions() {
    const series = elSeries.value;
    const subset = series ? filterData.filter(s => s.series === series) : filterData;

    // 対象シナリオの学年を収集（重複排除・ソート）
    const gradeSet = new Set();
    for (const s of subset) {
      if (s.grade) gradeSet.add(s.grade);
    }
    const grades = [...gradeSet].sort((a, b) => gradeNum(a) - gradeNum(b));

    const prev = elGrade.value;
    elGrade.innerHTML = '<option value="">すべての学年</option>';
    for (const g of grades) {
      const opt = document.createElement('option');
      opt.value = g;
      opt.textContent = g;
      if (g === prev) opt.selected = true;
      elGrade.appendChild(opt);
    }
  }

  function isFilterActive() {
    return elSeries.value || elGrade.value || elKeyword.value.trim();
  }

  function getFiltered() {
    const series = elSeries.value;
    const grade = elGrade.value;
    const keyword = elKeyword.value.trim().toLowerCase();

    return filterData.filter(s => {
      if (series && s.series !== series) return false;
      if (grade && !s.grade.includes(grade)) return false;
      if (keyword && !s.title.toLowerCase().includes(keyword) && !s.unit.toLowerCase().includes(keyword)) return false;
      return true;
    });
  }

  function renderCard(s) {
    const c = SERIES_COLORS[s.series] || SERIES_COLORS['time-travel'];
    const thumb = s.thumbnailUrl
      ? `<img src="${BASE}${s.thumbnailUrl.replace(/^\//, '')}" alt="" width="48" height="48" class="rounded object-cover w-12 h-12 flex-shrink-0" loading="lazy" />`
      : '';
    const gradeBadge = s.grade
      ? `<span class="text-xs text-amber-700">${s.grade}</span>`
      : '';
    return `
      <a href="${BASE}play/${s.slug}/" class="flex gap-2.5 items-center rounded-lg border border-gray-200 px-3 py-2.5 hover:shadow-md hover:border-gray-300 transition-all no-underline bg-white">
        ${thumb}
        <div class="min-w-0 flex-1">
          <div class="font-bold text-gray-900 text-sm leading-snug line-clamp-1">${s.title}</div>
          <div class="flex items-center gap-2 mt-0.5 text-xs text-gray-400">
            <span style="color:${c.color}" class="font-bold">${c.emoji} Vol.${s.volume}</span>
            ${gradeBadge}
            <span>${s.difficulty}</span>
          </div>
        </div>
        <span class="text-gray-300 text-sm flex-shrink-0">›</span>
      </a>
    `;
  }

  function renderResults() {
    const active = isFilterActive();

    // フィルタ未選択時: プロンプト表示
    elPrompt.classList.toggle('hidden', active);
    elCount.classList.toggle('hidden', !active);
    elResults.classList.toggle('hidden', !active);

    if (!active) {
      elResults.innerHTML = '';
      elEmpty.classList.add('hidden');
      elMoreWrap.classList.add('hidden');
      return;
    }

    const filtered = getFiltered();

    elCount.textContent = `${filtered.length}件のシナリオ`;
    elEmpty.classList.toggle('hidden', filtered.length > 0);

    // 上限付き表示
    const showing = filtered.slice(0, visibleCount);
    elResults.innerHTML = showing.map(renderCard).join('');

    // もっと見るボタン
    const remaining = filtered.length - visibleCount;
    if (remaining > 0) {
      elMoreWrap.classList.remove('hidden');
      elMoreBtn.textContent = `さらに${Math.min(remaining, PAGE_SIZE)}件を表示（残り${remaining}件）`;
    } else {
      elMoreWrap.classList.add('hidden');
    }
  }

  // イベント
  elSeries.addEventListener('change', () => {
    updateGradeOptions();
    visibleCount = PAGE_SIZE;
    renderResults();
  });
  elGrade.addEventListener('change', () => {
    visibleCount = PAGE_SIZE;
    renderResults();
  });
  elKeyword.addEventListener('input', () => {
    visibleCount = PAGE_SIZE;
    renderResults();
  });
  elMoreBtn.addEventListener('click', () => {
    visibleCount += PAGE_SIZE;
    renderResults();
  });

  // 初期化
  updateGradeOptions();
  renderResults();
</script>

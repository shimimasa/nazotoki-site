---
/**
 * プレイヤー用ページ — 授業投影用
 * プロジェクター投影を想定した大きめフォント
 * 秘密情報は一切含まない
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import EvidenceCard from '../../components/EvidenceCard.astro';
import { loadAllScenarios, type ScenarioData } from '../../lib/data';
import { getSeriesConfig } from '../../lib/series';
import { renderMarkdown } from '../../lib/markdown';

export function getStaticPaths() {
  const scenarios = loadAllScenarios();
  return scenarios.map(s => ({
    params: { slug: s.slug },
    props: { scenario: s },
  }));
}

const { scenario } = Astro.props as { scenario: ScenarioData };
const config = getSeriesConfig(scenario.series);
const commonHtml = renderMarkdown(scenario.common);
const playableChars = scenario.characters.filter(c => !c.isNPC);
---
<BaseLayout title={scenario.title} description={scenario.synopsis.split('\n')[0]}>
  {/* パンくず */}
  <nav class="text-sm text-gray-500 mb-6 print:hidden">
    <a href={import.meta.env.BASE_URL} class="hover:text-gray-700">トップ</a>
    <span class="mx-1">/</span>
    <a href={`${import.meta.env.BASE_URL}series/${scenario.series}/`} class={`hover:${config.text}`}>{scenario.seriesName}</a>
    <span class="mx-1">/</span>
    <span>Vol.{scenario.volume}</span>
  </nav>

  {/* ヘッダー */}
  <div class={`rounded-xl ${config.bgLight} border-2 ${config.border} p-6 mb-8`}>
    <span class={`text-xs font-bold ${config.text} uppercase`}>
      {config.emoji} {scenario.seriesName} Vol.{scenario.volume}
    </span>
    <h1 class="text-3xl sm:text-4xl font-black mt-2 leading-tight">{scenario.title}</h1>
    <div class="flex flex-wrap gap-4 mt-4 text-sm text-gray-600">
      <span>👥 {scenario.players.split('（')[0]}</span>
      <span>⏱ {scenario.time}</span>
      <span>📚 {scenario.subject}</span>
      <span>{scenario.difficulty}</span>
    </div>
  </div>

  {/* 共通情報 */}
  <section class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8 mb-8">
    <div class="prose prose-lg max-w-none play-content" set:html={commonHtml} />
  </section>

  {/* 証拠カード 1〜4 */}
  <section class="mb-8">
    <h2 class="text-2xl font-black mb-4">証拠カード</h2>
    <p class="text-sm text-gray-500 mb-4">タップして証拠を確認しよう。GMの指示に従って順番に開いてね。</p>
    <div class="space-y-3">
      {scenario.evidenceCards.map(card => (
        <EvidenceCard number={card.number} title={card.title} content={card.content} />
      ))}
    </div>
  </section>

  {/* 証拠カード 5 */}
  {scenario.evidence5 && (
    <section class="mb-8">
      <div class="space-y-3">
        <EvidenceCard
          number={5}
          title={scenario.evidence5.title}
          content={scenario.evidence5.content}
          isCard5={true}
        />
      </div>
    </section>
  )}

  {/* キャラクター一覧 */}
  <section class="mb-8">
    <h2 class="text-2xl font-black mb-4">登場人物</h2>
    <div class="grid gap-3 sm:grid-cols-2">
      {playableChars.map(char => (
        <a href={`${import.meta.env.BASE_URL}play/${scenario.slug}/${char.id}/`}
           class={`block rounded-lg border-2 ${config.border} ${config.bgLight} p-4 hover:shadow-md transition-shadow no-underline`}>
          <h3 class="font-bold text-lg text-gray-900">{char.name}</h3>
          <p class="text-sm text-gray-600 mt-1 line-clamp-2">{char.role}</p>
          <span class={`inline-block mt-2 text-xs font-bold ${config.text}`}>キャラシートを見る &rarr;</span>
        </a>
      ))}
    </div>
    <p class="text-sm text-gray-500 mt-3">
      各キャラクターシートには秘密情報が含まれます。自分のキャラクターだけを見てね。
    </p>
  </section>

  {/* NPC情報 */}
  {scenario.characters.filter(c => c.isNPC).length > 0 && (
    <section class="mb-8 bg-gray-100 rounded-lg p-4">
      <h3 class="font-bold text-gray-700 mb-2">NPC（GMが演じるキャラクター）</h3>
      <ul class="text-sm text-gray-600 space-y-1">
        {scenario.characters.filter(c => c.isNPC).map(char => (
          <li><strong>{char.name}</strong> — {char.role}</li>
        ))}
      </ul>
    </section>
  )}

  {/* 操作リンク */}
  <div class="flex flex-wrap gap-3 justify-center mt-12 print:hidden">
    <a href={`${import.meta.env.BASE_URL}print/${scenario.slug}/`}
       class="text-sm text-gray-500 hover:text-gray-700 underline">
      カード一式を印刷する
    </a>
    <button onclick="window.print()"
            class="text-sm text-gray-500 hover:text-gray-700 underline">
      このページを印刷する
    </button>
  </div>
  <div class="text-center mt-4 print:hidden">
    <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/`}
       class="text-xs text-gray-400 hover:text-gray-600 no-underline">
      GM（進行役）用ページへ →
    </a>
  </div>
</BaseLayout>

<style>
  /* 投影用: 大きめフォント */
  .play-content :global(p) {
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .play-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 900;
    margin-top: 2rem;
  }
  .play-content :global(blockquote) {
    border-left: 4px solid #d97706;
    padding-left: 1rem;
    font-style: normal;
    background: #fffbeb;
    padding: 0.75rem 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
</style>

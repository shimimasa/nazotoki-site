---
/**
 * プレイヤー用ページ — 授業投影用
 * プロジェクター投影を想定した大きめフォント
 * 秘密情報は一切含まない
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import EvidenceCard from '../../components/EvidenceCard.astro';
import { loadAllScenarios, type ScenarioData } from '../../lib/data';
import { getSeriesConfig } from '../../lib/series';
import { renderMarkdown } from '../../lib/markdown';
import curriculumData from '../../data/meta/curriculum.json';

export function getStaticPaths() {
  const scenarios = loadAllScenarios();
  return scenarios.map(s => ({
    params: { slug: s.slug },
    props: { scenario: s },
  }));
}

const { scenario } = Astro.props as { scenario: ScenarioData };
const config = getSeriesConfig(scenario.series);
const scenarios = loadAllScenarios();
const commonHtml = renderMarkdown(scenario.common);
const playableChars = scenario.characters.filter(c => !c.isNPC);
const npcs = scenario.characters.filter(c => c.isNPC);
const curriculum: Record<string, any> = curriculumData;
const cur = curriculum[scenario.slug];

// 同じ学年のおすすめシナリオ（自分自身を除く、最大4件、別シリーズ優先）
const sameGradeScenarios = cur?.grade
  ? scenarios
      .filter(s => s.slug !== scenario.slug && curriculum[s.slug]?.grade === cur.grade)
      .sort((a, b) => {
        // 別シリーズを優先
        const aDiff = a.series !== scenario.series ? 0 : 1;
        const bDiff = b.series !== scenario.series ? 0 : 1;
        return aDiff - bDiff || a.volume - b.volume;
      })
      .slice(0, 4)
  : [];
const seoDesc = cur
  ? `${cur.grade} ${cur.subject}「${cur.unit}」対応。${scenario.synopsis.split('\n')[0]}`
  : scenario.synopsis.split('\n')[0];
const synopsisFirst = scenario.synopsis.split('\n')[0];
---
<BaseLayout title={scenario.title} description={seoDesc} ogImage={scenario.thumbnailUrl} breadcrumbs={[{ name: 'トップ', url: import.meta.env.BASE_URL }, { name: scenario.seriesName, url: `${import.meta.env.BASE_URL}series/${scenario.series}/` }, { name: `Vol.${scenario.volume} ${scenario.title}` }]}>
  {/* パンくず */}
  <nav class="text-sm text-gray-500 mb-6 print:hidden">
    <a href={import.meta.env.BASE_URL} class="hover:text-gray-700">トップ</a>
    <span class="mx-1">/</span>
    <a href={`${import.meta.env.BASE_URL}series/${scenario.series}/`} class={`hover:${config.text}`}>{scenario.seriesName}</a>
    <span class="mx-1">/</span>
    <span>Vol.{scenario.volume}</span>
  </nav>

  {/* ヘッダー */}
  <header class={`rounded-2xl bg-white border ${config.border} overflow-hidden mb-8 shadow-sm`}>
    <div class="p-6 sm:p-8">
      <div class={`flex gap-5 ${scenario.thumbnailUrl ? 'items-start' : ''}`}>
        {scenario.thumbnailUrl && (
          <img
            src={`${import.meta.env.BASE_URL}${scenario.thumbnailUrl.replace(/^\//, '')}`}
            alt={scenario.title}
            width="120"
            height="120"
            class="rounded-xl object-cover w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 shadow-sm"
          />
        )}
        <div class="min-w-0">
          <span class={`text-xs font-bold ${config.text} uppercase tracking-wide`}>
            {config.emoji} {scenario.seriesName} Vol.{scenario.volume}
          </span>
          <h1 class="text-3xl sm:text-4xl font-black mt-2 leading-tight">{scenario.title}</h1>
          <p class="text-gray-600 mt-3 text-base leading-relaxed">{synopsisFirst}</p>
        </div>
      </div>
    </div>
    {/* メタ情報バー */}
    <div class={`border-t ${config.border} bg-white/60 px-6 sm:px-8 py-3 flex flex-wrap gap-x-6 gap-y-2 text-sm`}>
      <span class="flex items-center gap-1.5 text-gray-700"><span class="text-base">👥</span> {scenario.players.split('（')[0]}</span>
      <span class="flex items-center gap-1.5 text-gray-700"><span class="text-base">⏱</span> {scenario.time}</span>
      <span class="flex items-center gap-1.5 text-gray-700"><span class="text-base">📚</span> {scenario.subject}</span>
      <span class="text-gray-700">{scenario.difficulty}</span>
      {cur && (
        <>
          <span class="flex items-center gap-1.5">
            <span class="bg-amber-100 text-amber-800 font-bold rounded px-2 py-0.5 text-xs">{cur.grade}</span>
            <span class="text-gray-600">{cur.unit}</span>
          </span>
        </>
      )}
    </div>
  </header>

  {/* メインCTA */}
  <div class="flex flex-wrap gap-3 mb-2 print:hidden">
    <a href={`${import.meta.env.BASE_URL}session/${scenario.slug}/`}
       class={`inline-flex items-center gap-2 ${config.color} text-white px-6 py-3 rounded-xl font-bold hover:brightness-110 transition no-underline shadow-md flex-1 sm:flex-none justify-center`}>
      🎮 セッションモードで始める
    </a>
    <a href={`${import.meta.env.BASE_URL}solo/${scenario.slug}/`}
       class="inline-flex items-center gap-2 bg-indigo-500 text-white px-6 py-3 rounded-xl font-bold hover:bg-indigo-600 transition no-underline shadow-md flex-1 sm:flex-none justify-center">
      🔍 ソロモードで推理する
    </a>
    <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/`}
       class="inline-flex items-center gap-2 bg-gray-100 text-gray-700 px-6 py-3 rounded-xl font-bold hover:bg-gray-200 transition no-underline flex-1 sm:flex-none justify-center">
      📋 GM用ページ
    </a>
  </div>
  <div class="flex flex-wrap gap-x-6 gap-y-1 mb-8 text-xs text-gray-500 print:hidden px-1">
    <span>セッション: 先生が進行する教室・グループ向け（GM役が必要）</span>
    <span>ソロ: 1人で証拠を調べて推理する探偵ファイル形式</span>
  </div>

  {/* 共通情報 */}
  <section class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8 mb-8 shadow-sm">
    <h2 class="text-xl font-black text-gray-800 mb-4 flex items-center gap-2">
      <span class={`w-1 h-6 rounded-full ${config.color} inline-block`}></span>
      ストーリー
    </h2>
    <div class="prose prose-lg max-w-none play-content" set:html={commonHtml} />
  </section>

  {/* 登場人物 */}
  <section class="mb-8">
    <h2 class="text-xl font-black text-gray-800 mb-4 flex items-center gap-2">
      <span class={`w-1 h-6 rounded-full ${config.color} inline-block`}></span>
      登場人物
      <span class="text-sm font-normal text-gray-400 ml-1">{playableChars.length}人</span>
    </h2>
    <div class="grid gap-3 sm:grid-cols-2">
      {playableChars.map(char => (
        <a href={`${import.meta.env.BASE_URL}play/${scenario.slug}/${char.id}/`}
           class={`group block rounded-xl border ${config.border} bg-white p-4 shadow-sm hover:shadow-lg transition-all no-underline`}>
          <div class="flex gap-4 items-center">
            {char.imageUrl ? (
              <img
                src={`${import.meta.env.BASE_URL}${char.imageUrl.replace(/^\//, '')}`}
                alt={char.name}
                width="64"
                height="64"
                class="rounded-full object-cover w-14 h-14 flex-shrink-0 ring-2 ring-gray-100"
                loading="lazy"
              />
            ) : (
              <div class={`w-14 h-14 rounded-full ${config.bgLight} flex items-center justify-center flex-shrink-0`}>
                <span class="text-2xl">👤</span>
              </div>
            )}
            <div class="min-w-0 flex-1">
              <h3 class="font-bold text-lg text-gray-900">{char.name}</h3>
              <p class="text-sm text-gray-500 mt-0.5 line-clamp-1">{char.role}</p>
            </div>
            <span class={`text-lg ${config.text} group-hover:translate-x-1 transition-transform`}>&rarr;</span>
          </div>
        </a>
      ))}
    </div>
    <p class="text-xs text-gray-400 mt-3 text-center">
      自分のキャラクターだけを見てね（秘密情報が含まれます）
    </p>
  </section>

  {/* NPC情報 */}
  {npcs.length > 0 && (
    <section class="mb-8">
      <div class="bg-gray-50 rounded-xl border border-gray-200 p-4">
        <h3 class="font-bold text-gray-600 text-sm mb-2">NPC（GMが演じるキャラクター）</h3>
        <div class="flex flex-wrap gap-3">
          {npcs.map(char => (
            <span class="inline-flex items-center gap-1.5 bg-white rounded-lg border border-gray-200 px-3 py-1.5 text-sm">
              <strong class="text-gray-800">{char.name}</strong>
              <span class="text-gray-400">—</span>
              <span class="text-gray-500">{char.role}</span>
            </span>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* 証拠カード */}
  <section class="mb-8">
    <h2 class="text-xl font-black text-gray-800 mb-2 flex items-center gap-2">
      <span class={`w-1 h-6 rounded-full ${config.color} inline-block`}></span>
      証拠カード
    </h2>
    <p class="text-sm text-gray-400 mb-4">タップして証拠を確認しよう。GMの指示に従って順番に開いてね。</p>
    <div class="space-y-3">
      {scenario.evidenceCards.map(card => (
        <EvidenceCard number={card.number} title={card.title} content={card.content} />
      ))}
    </div>
  </section>

  {/* 証拠カード 5 */}
  {scenario.evidence5 && (
    <section class="mb-8">
      <div class="space-y-3">
        <EvidenceCard
          number={5}
          title={scenario.evidence5.title}
          content={scenario.evidence5.content}
          isCard5={true}
        />
      </div>
    </section>
  )}

  {/* === 同じ学年のおすすめ === */}
  {sameGradeScenarios.length > 0 && (
    <section class="mt-10 print:hidden">
      <h2 class="text-xl font-black text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-6 rounded-full bg-amber-400 inline-block"></span>
        {cur.grade}のおすすめシナリオ
      </h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {sameGradeScenarios.map(s => {
          const sc = getSeriesConfig(s.series);
          const sCur = curriculum[s.slug];
          return (
            <a href={`${import.meta.env.BASE_URL}play/${s.slug}/`}
               class={`flex gap-3 items-center rounded-xl border ${sc.border} bg-white p-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline`}>
              {s.thumbnailUrl && (
                <img src={`${import.meta.env.BASE_URL}${s.thumbnailUrl.replace(/^\//, '')}`}
                     alt={`${s.title} サムネイル`} width="48" height="48"
                     class="rounded-lg object-cover w-12 h-12 flex-shrink-0" loading="lazy" />
              )}
              <div class="min-w-0 flex-1">
                <div class="font-bold text-gray-900 text-sm leading-snug line-clamp-1">{s.title}</div>
                <div class="flex items-center gap-2 mt-0.5 text-xs text-gray-500">
                  <span class={`font-bold ${sc.text}`}>{sc.emoji} {sc.name}</span>
                  {sCur?.unit && <span class="text-gray-400">{sCur.unit}</span>}
                </div>
              </div>
              <span class={`${sc.text} flex-shrink-0`}>&rarr;</span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {/* === F. プレイ後の導線 === */}
  <section class="mt-12 pt-8 border-t-2 border-gray-100 print:hidden">
    <h2 class="text-xl font-black text-gray-800 mb-4 text-center">次のステップ</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <a href={`${import.meta.env.BASE_URL}gm/${scenario.slug}/`}
         class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">📋</span>
        <span class="font-bold text-gray-800 text-sm">GM用の進行ガイド</span>
        <span class="text-xs text-gray-500">真相・進行手順を確認</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}series/${scenario.series}/`}
         class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">{config.emoji}</span>
        <span class="font-bold text-gray-800 text-sm">同じシリーズを見る</span>
        <span class="text-xs text-gray-500">{scenario.seriesName}</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}solo/${scenario.slug}/`}
         class="flex flex-col items-center gap-2 rounded-xl border border-indigo-200 bg-indigo-50 p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">🔍</span>
        <span class="font-bold text-indigo-800 text-sm">ソロモードで推理</span>
        <span class="text-xs text-indigo-600">1人で謎解きに挑戦</span>
      </a>
      <a href={import.meta.env.BASE_URL}
         class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline">
        <span class="text-2xl">📚</span>
        <span class="font-bold text-gray-800 text-sm">他のシナリオを探す</span>
        <span class="text-xs text-gray-500">全{scenarios.length}シナリオ無料</span>
      </a>
    </div>
  </section>

  {/* フッターリンク */}
  <div class="mt-6 pt-4 border-t border-gray-200 print:hidden">
    <div class="flex flex-wrap gap-3 justify-center">
      <a href={`${import.meta.env.BASE_URL}print/${scenario.slug}/`}
         class="text-sm text-gray-500 hover:text-gray-700 no-underline flex items-center gap-1">
        🖨 カード一式を印刷
      </a>
      <span class="text-gray-300">|</span>
      <button onclick="window.print()"
              class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
        📄 このページを印刷
      </button>
    </div>
  </div>
</BaseLayout>

<style>
  /* 投影用: 大きめフォント */
  .play-content :global(p) {
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .play-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 900;
    margin-top: 2rem;
  }
  .play-content :global(blockquote) {
    border-left: 4px solid #d97706;
    padding-left: 1rem;
    font-style: normal;
    background: #fffbeb;
    padding: 0.75rem 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
</style>

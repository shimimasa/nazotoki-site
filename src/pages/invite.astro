---
import BaseLayout from '../layouts/BaseLayout.astro';
import InviteGate from '../components/workspace/InviteGate';
---
<BaseLayout
  title="招待を受け入れる"
  description="学校への招待を受け入れてチームに参加"
  noIndex={true}
>
  <nav class="text-sm text-gray-500 mb-6">
    <a href={import.meta.env.BASE_URL} class="hover:text-gray-700">トップ</a>
    <span class="mx-1">/</span>
    <span>招待</span>
  </nav>

  <InviteGate client:load />
</BaseLayout>

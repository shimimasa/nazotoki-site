---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="オフライン" noIndex>
  <div class="text-center py-16">
    <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-slate-100 flex items-center justify-center">
      <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
      </svg>
    </div>
    <h1 class="text-2xl font-black text-slate-800 mb-3">インターネットに接続できません</h1>
    <p class="text-slate-600 mb-6">このページはオフラインでは表示できません。<br />接続を確認してからもう一度お試しください。</p>
    <button onclick="location.reload()" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-bold px-6 py-3 rounded-lg shadow transition-all">
      再読み込み
    </button>
  </div>
</BaseLayout>

---
/**
 * 印刷用 キャラクターカード — 秘密情報含む全文、1枚/ページ
 * ふりがな保持（子ども向け印刷物）
 */
import { renderMarkdown } from '../lib/markdown';

interface Props {
  name: string;
  scenarioTitle: string;
  fullContent: string;
  imageUrl?: string;
}

const { name, scenarioTitle, fullContent, imageUrl } = Astro.props;
const html = renderMarkdown(fullContent, true);
---
<section class="print-card">
  <div class="print-card-header flex items-center justify-between">
    <div class="flex items-center gap-2">
      {imageUrl && (
        <img
          src={`${import.meta.env.BASE_URL}${imageUrl.replace(/^\//, '')}`}
          alt={name}
          width="40"
          height="40"
          class="rounded-full object-cover w-10 h-10"
        />
      )}
      <span>キャラクターカード: {name}</span>
    </div>
    <span class="text-sm font-normal text-gray-600">{scenarioTitle}</span>
  </div>
  <div class="prose prose-sm max-w-none" set:html={html} />
</section>

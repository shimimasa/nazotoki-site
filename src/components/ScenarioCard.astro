---
import { getSeriesConfig } from '../lib/series';

interface Props {
  slug: string;
  title: string;
  series: string;
  volume: number;
  difficulty: string;
  synopsis: string;
  players: string;
  time: string;
}

const { slug, title, series, volume, difficulty, synopsis, players, time } = Astro.props;
const config = getSeriesConfig(series);
---
<a href={`${import.meta.env.BASE_URL}play/${slug}/`}
   class={`block rounded-lg border-2 ${config.border} ${config.bgLight} p-4 hover:shadow-md transition-shadow no-underline`}>
  <div class="flex items-start justify-between gap-2">
    <div>
      <span class={`text-xs font-bold ${config.text} uppercase`}>Vol.{volume}</span>
      <h3 class="text-lg font-bold text-gray-900 mt-1 leading-snug">{title}</h3>
    </div>
    <span class="text-sm text-gray-500 whitespace-nowrap">{difficulty}</span>
  </div>
  <p class="text-sm text-gray-600 mt-2 line-clamp-2">{synopsis}</p>
  <div class="flex gap-3 mt-3 text-xs text-gray-500">
    <span>{players}</span>
    <span>{time}</span>
  </div>
</a>

---
import { getSeriesConfig } from '../lib/series';

interface Props {
  slug: string;
  title: string;
  series: string;
  volume: number;
  difficulty: string;
  synopsis: string;
  players: string;
  time: string;
  thumbnailUrl?: string;
  grade?: string;
  unit?: string;
}

const { slug, title, series, volume, difficulty, synopsis, players, time, thumbnailUrl, grade, unit } = Astro.props;
const config = getSeriesConfig(series);
---
<div class={`rounded-xl border ${config.border} bg-white p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all`}>
  <a href={`${import.meta.env.BASE_URL}play/${slug}/`} class="block no-underline">
    <div class={`flex gap-3 ${thumbnailUrl ? 'items-start' : ''}`}>
      {thumbnailUrl && (
        <img
          src={`${import.meta.env.BASE_URL}${thumbnailUrl.replace(/^\//, '')}`}
          alt={title}
          width="80"
          height="80"
          class="rounded-md object-cover w-20 h-20 flex-shrink-0"
          loading="lazy"
        />
      )}
      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-2">
          <div>
            <span class={`text-xs font-bold ${config.text} uppercase`}>Vol.{volume}</span>
            <h3 class="text-lg font-bold text-gray-900 mt-1 leading-snug">{title}</h3>
          </div>
          <span class="text-sm text-gray-500 whitespace-nowrap">{difficulty}</span>
        </div>
        <p class="text-sm text-gray-600 mt-2 line-clamp-2">{synopsis}</p>
        {(grade || unit) && (
          <div class="mt-2 text-xs text-amber-700 bg-amber-50 rounded px-2 py-1 inline-block">
            {grade && <span class="font-bold">{grade}</span>}
            {grade && unit && <span class="mx-1">|</span>}
            {unit && <span>{unit}</span>}
          </div>
        )}
        <div class="flex gap-3 mt-2 text-xs text-gray-500">
          <span>{players}</span>
          <span>{time}</span>
        </div>
      </div>
    </div>
  </a>
  <div class="flex gap-3 mt-3 pt-2.5 border-t border-slate-100 text-xs">
    <a href={`${import.meta.env.BASE_URL}play/${slug}/`} class={`font-bold ${config.text} no-underline hover:underline`}>プレイヤー用</a>
    <a href={`${import.meta.env.BASE_URL}gm/${slug}/`} class="font-bold text-slate-400 no-underline hover:underline hover:text-slate-700">GM用</a>
  </div>
</div>

# ============================================================
# ナゾトキ探偵団 セッションプラットフォーム - 環境変数
# ============================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# PUBLIC_ プレフィックス: クライアント（ブラウザ）に公開される変数
# プレフィックスなし: サーバーサイド（APIルート）でのみ使用される変数
# ============================================================

# -----------------------------------------------------------
# Supabase（必須）
# supabase.com → プロジェクト設定 → API で取得
# -----------------------------------------------------------

# クライアントサイドで使用する接続情報
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# サーバーサイドAPIで使用するサービスロールキー
# ※ このキーはRLSを迂回するため、絶対にクライアントに公開しないこと
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# -----------------------------------------------------------
# Sentry エラー監視（任意）
# sentry.io → プロジェクト設定 → Client Keys (DSN) で取得
# -----------------------------------------------------------

# 設定しない場合、エラー監視は無効になる
# PUBLIC_SENTRY_DSN=https://xxxxx@o12345.ingest.sentry.io/12345

# -----------------------------------------------------------
# Resend メール送信（任意）
# resend.com → API Keys で取得
# 教師招待メール送信に使用
# -----------------------------------------------------------

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# 送信元メールアドレス（ドメイン認証済みのアドレスを指定）
# 未設定の場合は onboarding@resend.dev が使用される
# INVITE_EMAIL_FROM=noreply@nazotoki.gamanavi.com

# -----------------------------------------------------------
# Stripe 決済（任意）
# stripe.com → Developers → API keys で取得
# サブスクリプション課金に使用
# -----------------------------------------------------------

# シークレットキー（sk_test_ で始まるテストキーを使用）
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Webhookシークレット（stripe listen --forward-to で取得、または Stripe Dashboard で確認）
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxx

# 料金プランID（Stripe Dashboard → Products → Prices で作成後にコピー）
# STRIPE_PRICE_ID_STANDARD=price_xxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_ID_SCHOOL=price_xxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# Anthropic AI分析（任意）
# console.anthropic.com → API Keys で取得
# 投票理由のAI分析機能に使用
# -----------------------------------------------------------

# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx
